    def _pur_add_item(self):
        prod = self._p_prod.get().strip()
        if not prod:
            messagebox.showerror("Error","Product select karo!"); return
        try:
            qty  = float(self._p_qty.get())
            rate = float(self._p_rate.get())
            gst  = float(self._p_gst.get())
            disc_val = float(self._p_disc.get() or 0)
        except:
            messagebox.showerror("Error","Qty aur Rate sahi numbers bharo!"); return
        if qty <= 0:
            messagebox.showerror("Error","Qty 0 se zyada honi chahiye!"); return
        size      = self._p_size.get().strip()
        color     = self._p_color.get().strip()
        ptype     = self._p_type_var.get()
        category  = self._p_cat_var.get()
        hsn       = self._p_hsn_var.get()

        # Discount: % ya ₹
        dtype = getattr(self,"_p_disc_type",None)
        dtype_val = dtype.get() if dtype else "%"
        if dtype_val == "₹":
            disc_amt = disc_val
            disc_pct = round(disc_val / rate * 100, 2) if rate else 0
        else:
            disc_pct = disc_val
            disc_amt = round(rate * disc_pct / 100, 2)

        rate_net  = rate - disc_amt
        taxable   = round(qty * rate_net, 2)
        gst_amt   = round(taxable * gst / 100, 2)
        total     = round(taxable + gst_amt, 2)
        # sale_rate update if user changed it
        try:
            new_srate = float(self._p_sale_rate_var.get() or 0)
        except:
            new_srate = 0
        if new_srate > 0:
            pr2 = self._p_prod_dict.get(prod)
            if pr2 and pr2.get("sale_rate",0) != new_srate:
                try:
                    conn2 = get_db()
                    conn2.execute("UPDATE products SET sale_rate=?, purchase_rate=? WHERE name=?",
                                  (new_srate, rate, prod))
                    conn2.commit(); conn2.close()
                    pr2["sale_rate"] = new_srate
                    pr2["purchase_rate"] = rate
                except: pass

        self._pur_items.append({
            "product": prod, "product_type": ptype, "category": category,
            "hsn": hsn, "size": size, "color": color,
            "qty": qty, "rate": rate, "discount": disc_pct,
            "disc_amt": disc_amt, "disc_type": dtype_val,
            "taxable": taxable, "gst": gst, "gst_amt": gst_amt, "total": total
        })
        self._pur_render()
        self._p_qty.set("")
        self._p_disc.set("0")
        self._p_size.set("")
        self._p_color.set("")
        self._p_stock_lbl.config(text="")

    def _pur_render(self):
        clear_table_rows(self._p_tbl)
        total_sum = 0
        for i,it in enumerate(self._pur_items):
            total_sum += it["total"]
            bg = C_WHITE if i%2==0 else "#F7FAFC"
            _dv=it.get('discount',0); _dt=it.get('disc_type','%'); _da=it.get('disc_amt',0)
            disc_str=(f'₹{_da:.0f}' if _dt=='₹' else f'{_dv}%') if _dv else '-'
            desc = it["product"][:16]
            if it.get("size"):  desc += f" [{it['size']}]"
            if it.get("color"): desc += f" {it['color']}"
            vals = [
                i+1,
                desc,
                it.get("product_type",""),
                it.get("category",""),
                it.get("hsn",""),
                it["qty"],
                f"₹{it['rate']:.2f}",
                disc_str,
                f"₹{it['taxable']:.2f}",
                f"{it['gst']}%",
                f"₹{it['gst_amt']:.2f}",
                f"₹{it['total']:.0f}",
                "✕"
            ]
            for j,val in enumerate(vals):
                if j==12:
                    tk.Button(self._p_tbl,text="✕",font=("Segoe UI",9),
                              bg=bg,fg=C_RED,relief="flat",cursor="hand2",bd=0,
                              command=lambda idx=i: self._pur_del(idx)
                              ).grid(row=i+1,column=j,sticky="nsew",padx=1)
                else:
                    tk.Label(self._p_tbl,text=str(val),font=("Segoe UI",9),
                             bg=bg,fg=C_GRAY,anchor="w",padx=6,pady=4
                             ).grid(row=i+1,column=j,sticky="nsew",padx=1)
        self._p_total.set(f"₹{round(total_sum):,}")
        if hasattr(self,"_p_words_var"):
            self._p_words_var.set(num_to_words(total_sum))

    def _pur_del(self,idx):
        self._pur_items.pop(idx); self._pur_render()

    def _pur_save(self):
        if not self._pur_items:
            messagebox.showerror("Error","Koi item nahi!"); return
        bill_no = self._p_billno.get().strip()
        if not bill_no:
            messagebox.showerror("Error","Purchase number bharo!"); return
        date    = self._p_date.get().strip()
        party   = self._p_party.get().strip() or "Supplier"
        grand   = sum(it["total"] for it in self._pur_items)
        conn = get_db()
        try:
            c = conn.cursor()
            pay_mode = getattr(self, "_p_paymode", None)
            due_date = getattr(self, "_p_due", None)
            pm = pay_mode.get() if pay_mode else "Cash"
            dd = due_date.get().strip() if due_date else ""
            c.execute("INSERT INTO purchases(bill_no,bill_date,party,grand_total,pay_mode,due_date) VALUES(?,?,?,?,?,?)",
                      (bill_no,date,party,grand,pm,dd))
            pid = c.lastrowid
            for it in self._pur_items:
                c.execute("""INSERT INTO purchase_items
                    (purchase_id,product,qty,rate,taxable,gst_percent,gst_amt,total,
                     size,color,discount,hsn)
                    VALUES(?,?,?,?,?,?,?,?,?,?,?,?)""",
                    (pid, it["product"], it["qty"], it["rate"],
                     it["taxable"], it["gst"], it["gst_amt"], it["total"],
                     it.get("size",""), it.get("color",""), it.get("discount",0),
                     it.get("hsn","")))

                # ── Auto: Products table update / create ──────────────────────
                prod_name = it["product"].strip()
                existing  = conn.execute(
                    "SELECT id FROM products WHERE name=?", (prod_name,)).fetchone()
                if existing:
                    # Product exist karta hai — sirf purchase_rate update karo
                    c.execute(
                        "UPDATE products SET purchase_rate=?, gst_percent=? WHERE name=?",
                        (it["rate"], it["gst"], prod_name))
                else:
                    # Naya product — auto-create karo sane defaults ke saath
                    c.execute("""INSERT OR IGNORE INTO products
                        (name, purchase_rate, sale_rate, gst_percent, opening_stock,
                         hsn, category, brand, product_type,
                         size_options, color_options, barcode, low_stock_alert)
                        VALUES (?,?,?,?,0, '','','','Clothes', '','','',5)""",
                        (prod_name, it["rate"],
                         round(it["rate"] * 1.3, 2),   # sale_rate = purchase_rate + 30% default margin
                         it["gst"]))
            # ── Auto payment entry — Cash/UPI/Bank/Cheque pe turant paid mark karo ──
            if pm != "Credit":
                c.execute(
                    "INSERT INTO bill_payments(bill_type,bill_no,party,pay_date,amount,pay_mode,note) VALUES(?,?,?,?,?,?,?)",
                    ("pur", bill_no, party, date, grand, pm, "Auto-paid at billing")
                )
            conn.commit()
            messagebox.showinfo("Saved",
                f"Purchase saved!\n{bill_no}\n"
                f"Taxable: ₹{round(sum(it['taxable'] for it in self._pur_items)):,}\n"
                f"GST: ₹{round(sum(it['gst_amt'] for it in self._pur_items)):,}\n"
                f"Total: ₹{round(grand):,}")
            self._pur_items=[]; self._show("purchase")
        except sqlite3.IntegrityError:
            messagebox.showerror("Error","Bill number already exists! Alag number use karo.")
        finally:
            conn.close()

    def _pur_clear(self):
        self._pur_items = []
        self._pur_render()
        # Reset all fields
        try:
            self._p_prod.set("")
            self._p_type_var.set(""); self._p_cat_var.set("")
            self._p_brand_var.set(""); self._p_hsn_var.set("")
            self._p_qty.set(""); self._p_rate.set("")
            self._p_disc.set("0"); self._p_size.set(""); self._p_color.set("")
            self._p_sale_rate_var.set(""); self._p_stock_lbl.config(text="")
            self._p_gst.set("5")
        except: pass

