MON = ["","Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]

def fmt_date(d):
    try:
        y,m,dd = d.split("-")
        return f"{dd}-{MON[int(m)]}-{y}"
    except:
        return d or ""

def today_str():
