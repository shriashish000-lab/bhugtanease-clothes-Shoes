    def _print_return_pdf_history(self, rno, orig_bill, party, items, ret_date, grand, reason, rtype):
        """Return Bill PDF banao aur open karo (History pages ke liye shared)."""
        try:
            from reportlab.lib.pagesizes import A4
            from reportlab.lib import colors
            from reportlab.lib.units import mm
            from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer
            from reportlab.lib.styles import ParagraphStyle
            from reportlab.lib.enums import TA_CENTER, TA_RIGHT, TA_LEFT
            from tkinter import filedialog
            import os, sys

            save_path = filedialog.asksaveasfilename(
                defaultextension=".pdf",
                filetypes=[("PDF","*.pdf")],
                initialfile=f"{rno}.pdf",
                title="Return Bill PDF save karo")
            if not save_path: return

            _sp = get_shop()
            PAGE_W = 190*mm
            BDR = colors.black

            def ps(nm, sz=9, bold=False, align=TA_LEFT):
                return ParagraphStyle(nm, fontSize=sz,
                    fontName="Helvetica-Bold" if bold else "Helvetica",
                    alignment=align, leading=sz+3)

            BASE = [("BOX",(0,0),(-1,-1),0.5,BDR),
                    ("INNERGRID",(0,0),(-1,-1),0.3,BDR),
                    ("TOPPADDING",(0,0),(-1,-1),3),
                    ("BOTTOMPADDING",(0,0),(-1,-1),3),
                    ("LEFTPADDING",(0,0),(-1,-1),3),
                    ("RIGHTPADDING",(0,0),(-1,-1),3)]

            doc = SimpleDocTemplate(save_path, pagesize=A4,
                leftMargin=12*mm, rightMargin=12*mm,
                topMargin=10*mm, bottomMargin=10*mm)
            story = []

            RED = colors.HexColor("#9B2C2C")

            story.append(Table([[Paragraph(rtype.upper(), ps("t",13,True,TA_CENTER))]],
                [PAGE_W], [("BOX",(0,0),(-1,-1),1,RED),
                           ("BACKGROUND",(0,0),(-1,-1),RED),
                           ("TEXTCOLOR",(0,0),(-1,-1),colors.white),
                           ("TOPPADDING",(0,0),(-1,-1),6),
                           ("BOTTOMPADDING",(0,0),(-1,-1),6)]))
            story.append(Spacer(1, 2*mm))

            shop_txt = (f"<b>{_sp['name']}</b><br/>"
                + (f"{_sp['address']}, {_sp['city']}<br/>" if _sp['address'] else "")
                + (f"Mob: {_sp['mobile']}<br/>" if _sp['mobile'] else "")
                + (f"GSTIN: {_sp['gstin']}" if _sp['gstin'] else ""))
            bill_info = (f"<b>Return No:</b> {rno}<br/>"
                f"<b>Date:</b> {fmt_date(ret_date)}<br/>"
                f"<b>Against Bill:</b> {orig_bill}<br/>"
                f"<b>Party:</b> {party}"
                + (f"<br/><b>Reason:</b> {reason}" if reason else ""))

            story.append(Table([[Paragraph(shop_txt,ps("sh",9)),
                                 Paragraph(bill_info,ps("bi",9))]],
                [110*mm, 80*mm], BASE))

            hdr = [Paragraph(x, ps("h",8,True,TA_CENTER)) for x in
                   ["Sl","Product","Qty","Rate(₹)","GST%","GST Amt","Total(₹)"]]
            rows = [hdr]
            total_taxable = 0; total_gst_sum = 0
            for i,it in enumerate(items,1):
                taxbl = round(it["qty"]*it["rate"],2)
                total_taxable += taxbl; total_gst_sum += it["gst_amt"]
                rows.append([
                    Paragraph(str(i),ps("r",8,align=TA_CENTER)),
                    Paragraph(it["product"],ps("r",8)),
                    Paragraph(str(it["qty"]),ps("r",8,align=TA_CENTER)),
                    Paragraph(f"{it['rate']:.2f}",ps("r",8,align=TA_RIGHT)),
                    Paragraph(f"{it['gst_percent']}%",ps("r",8,align=TA_CENTER)),
                    Paragraph(f"{it['gst_amt']:.2f}",ps("r",8,align=TA_RIGHT)),
                    Paragraph(f"{it['total_amt']:.2f}",ps("r",8,align=TA_RIGHT)),
                ])
            rows.append([Paragraph(""),Paragraph("<b>Total</b>",ps("r",9,True)),
                Paragraph(""),Paragraph(""),Paragraph(""),
                Paragraph(f"<b>{total_gst_sum:.2f}</b>",ps("r",9,True,TA_RIGHT)),
                Paragraph(f"<b>{grand:.2f}</b>",ps("r",9,True,TA_RIGHT))])

            story.append(Spacer(1,3*mm))
            story.append(Table(rows,[10*mm,70*mm,18*mm,22*mm,14*mm,22*mm,24*mm],
                BASE+[("BACKGROUND",(0,0),(-1,0),colors.HexColor("#FDEBD0")),
                      ("BACKGROUND",(0,-1),(-1,-1),colors.HexColor("#FFF5F5"))]))

            story.append(Spacer(1,2*mm))
            story.append(Table([
                [Paragraph(f"Amount: <b>{num_to_words(grand)}</b>",ps("aw",8))],
                [Paragraph(f"Reason: {reason}" if reason else "",ps("aw",8,"italic"))]],
                [PAGE_W], BASE))

            story.append(Spacer(1,4*mm))
            story.append(Table([[Paragraph(""),
                Paragraph(f"For {_sp['name']}<br/><br/><br/>Authorized Signatory",
                           ps("sg",9,align=TA_RIGHT))]],
                [110*mm,80*mm], BASE+[("BOTTOMPADDING",(0,0),(-1,-1),18)]))

            doc.build(story)
            import subprocess
            if sys.platform=="win32": os.startfile(save_path)
            elif sys.platform=="darwin": subprocess.Popen(["open",save_path])
            else: subprocess.Popen(["xdg-open",save_path])
            messagebox.showinfo("PDF Ready!", f"Return Bill PDF save ho gayi:\n{save_path}")
        except ImportError:
            messagebox.showerror("Library Missing",
                "reportlab install nahi hai.\n\nCMD mein chalao:\npip install reportlab")
        except Exception as e:
            messagebox.showerror("Error", f"PDF nahi ban saki:\n{str(e)}")

    def _pg_exchangehistory(self):
        # Exchange tables sirf _pg_exchange visit karne par bante the — agar user
        # seedha History pe aaye to bhi table maujood honi chahiye.
        _d0 = get_db()
        _d0.execute("""CREATE TABLE IF NOT EXISTS exchanges (
            id              INTEGER PRIMARY KEY AUTOINCREMENT,
            exchange_no     TEXT UNIQUE NOT NULL,
            exchange_date   TEXT NOT NULL,
            orig_bill       TEXT NOT NULL,
            party           TEXT NOT NULL,
            diff_amount     REAL DEFAULT 0,
            payment_mode    TEXT DEFAULT 'Cash',
            reason          TEXT DEFAULT '',
            created_at      TEXT DEFAULT CURRENT_TIMESTAMP)""")
        _d0.execute("""CREATE TABLE IF NOT EXISTS exchange_return_items (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            exchange_no TEXT NOT NULL,
            product     TEXT NOT NULL,
            qty         REAL DEFAULT 0,
            rate        REAL DEFAULT 0,
            gst_pct     REAL DEFAULT 0,
            gst_amt     REAL DEFAULT 0,
            total_amt   REAL DEFAULT 0)""")
        _d0.execute("""CREATE TABLE IF NOT EXISTS exchange_new_items (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            exchange_no TEXT NOT NULL,
            product     TEXT NOT NULL,
            qty         REAL DEFAULT 0,
            rate        REAL DEFAULT 0,
            gst_pct     REAL DEFAULT 0,
            gst_amt     REAL DEFAULT 0,
            total_amt   REAL DEFAULT 0)""")
