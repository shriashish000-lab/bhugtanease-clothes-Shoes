                "ORDER BY damage_date ASC").fetchall()
            d.close()
            today = _dt.date.today()
            for i, r in enumerate(rows):
                bg = C_WHITE if i%2==0 else "#FFFBEB"
                try:
                    days_old = (today - _dt.date.fromisoformat(r["damage_date"])).days
                except:
                    days_old = "-"
                age_clr = C_RED if isinstance(days_old,int) and days_old > 30 else                           C_AMBER if isinstance(days_old,int) and days_old > 7 else C_GRAY
                vals = [r["damage_no"], r["damage_date"], r["product"][:16], int(r["qty"]),
