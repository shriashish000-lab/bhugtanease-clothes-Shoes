            except:
                messagebox.showerror("Error","Qty aur Rate sahi bharo!"); return
            tax = round(q*r2,2); ga = round(tax*g/100,2); tot = round(tax+ga,2)
            _ret_items.append({"product":prod,"qty":q,"rate":r2,"gst_pct":g,"gst_amt":ga,"total_amt":tot})
            render_both()
            v_rp.set(""); v_rq.set("1"); v_rrate.set(""); v_rgst.set("0")

        def clear_ret_fields():
            v_rp.set(""); v_rq.set("1"); v_rrate.set(""); v_rgst.set("0")

        make_btn(lr, "+ Add", add_ret, bg=C_RED, font_size=8, padx=6, pady=3).pack(side="left", padx=(0,2))
        make_btn(lr, "Clear", clear_ret_fields, bg=C_GRAY, font_size=8, padx=6, pady=3).pack(side="left")

        ret_tbl = make_table(lf, ["#","Product","Qty","Rate","Total","\u2715"],
                             [3,20,5,8,9,3])

        v_ret_tot_lbl = tk.StringVar(value="Wapas Total: \u20b90")
        tk.Label(lf, textvariable=v_ret_tot_lbl, font=("Segoe UI", 10, "bold"),
                 bg="#FFF5F5", fg="#9B2C2C").pack(anchor="w", padx=10, pady=(2,8))

