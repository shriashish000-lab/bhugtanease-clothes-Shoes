        p = tk.Frame(self.content, bg=C_BG, padx=14, pady=6)
        p.pack(fill="x")
        section_title(p, "Exchange History")

        ff = tk.Frame(p, bg=C_BG); ff.pack(fill="x", pady=(0,10))
