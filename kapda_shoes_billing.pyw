        def change_password():
            old = v_old_pwd.get()
            new = v_new_pwd.get().strip()
            confirm = v_confirm_pwd.get().strip()

            if not old:
                pwd_status.config(text="❌ Purana password bharo!", fg=C_RED); return
            if not new:
                pwd_status.config(text="❌ Naya password bharo!", fg=C_RED); return
            if len(new) < 4:
                pwd_status.config(text="❌ Password kam se kam 4 characters ka hona chahiye!", fg=C_RED); return
            if new != confirm:
                pwd_status.config(text="❌ Naya password aur confirm password match nahi kar rahe!", fg=C_RED); return

            conn = get_db()
            import hashlib as _hl
            old = _hl.sha256(old.encode()).hexdigest()
            new = _hl.sha256(new.encode()).hexdigest()
            row = conn.execute("SELECT id FROM users WHERE password=?", (old,)).fetchone()
            if not row:
                conn.close()
                pwd_status.config(text="❌ Purana password galat hai!", fg=C_RED); return

            conn.execute("UPDATE users SET password=? WHERE id=?", (new, row["id"]))
            conn.commit(); conn.close()

            v_old_pwd.set(""); v_new_pwd.set(""); v_confirm_pwd.set("")
            pwd_status.config(text="✅ Password safaltapoorvak badal gaya! Agli baar login me naya password use karo.",
