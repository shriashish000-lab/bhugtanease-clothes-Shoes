        def import_parties_excel():
            try:
                import openpyxl
            except ImportError:
                messagebox.showerror("openpyxl Missing","pip install openpyxl"); return
            from tkinter import filedialog
            filepath = filedialog.askopenfilename(
                title="Parties Excel File Select Karo",
                filetypes=[("Excel Files","*.xlsx *.xls"),("All Files","*.*")])
            if not filepath: return
            try:
                wb = openpyxl.load_workbook(filepath, data_only=True)
                ws = wb.active
                headers = [str(c.value or "").strip().lower() for c in ws[1]]
                col = {
                    "name":  next((i for i,h in enumerate(headers) if "party" in h or "name" in h), None),
                    "type":  next((i for i,h in enumerate(headers) if "type" in h), None),
                    "mob":   next((i for i,h in enumerate(headers) if "mob" in h or "phone" in h), None),
                    "gstin": next((i for i,h in enumerate(headers) if "gst" in h), None),
                    "state": next((i for i,h in enumerate(headers) if "state" in h), None),
                    "email": next((i for i,h in enumerate(headers) if "email" in h), None),
                    "addr":  next((i for i,h in enumerate(headers) if "addr" in h), None),
                }
                if col["name"] is None:
                    messagebox.showerror("Column Error","'Party Name' column nahi mila!\nPehle template download karo.")
                    return
                def gv(row, k, d=""):
                    idx = col.get(k)
                    if idx is None or idx >= len(row): return d
                    v = row[idx]
                    return str(v).strip() if v is not None else d
                conn = get_db(); added = skipped = 0; errors = []
                for rn, row in enumerate(ws.iter_rows(min_row=2, values_only=True), 2):
                    rv = list(row)
                    if not any(v for v in rv): continue
                    name = gv(rv, "name")
                    if not name or name.lower() == "none": continue
                    if conn.execute("SELECT id FROM parties WHERE name=?", (name,)).fetchone():
                        skipped += 1; continue
                    try:
                        conn.execute(
                            "INSERT INTO parties(name,ptype,mobile,gstin,address,state,email) VALUES(?,?,?,?,?,?,?)",
                            (name, gv(rv,"type","Customer"), gv(rv,"mob",""),
                             gv(rv,"gstin",""), gv(rv,"addr",""),
                             gv(rv,"state","Uttar Pradesh"), gv(rv,"email",""))
                        )
                        added += 1
                    except sqlite3.IntegrityError: skipped += 1
                    except Exception as e: errors.append(f"Row {rn}: {e}")
                conn.commit(); conn.close(); refresh()
                msg = f"✅ Import Complete!\n\n✔ Naye parties add hue: {added}\n⏭ Skip (already exist): {skipped}"
                if errors: msg += "\n\n⚠ Errors:\n" + "\n".join(errors[:5])
                messagebox.showinfo("Parties Import", msg)
            except Exception as e:
                messagebox.showerror("Import Error", str(e))

        def download_parties_template():
            try:
                import openpyxl
                from openpyxl.styles import Font, PatternFill, Alignment
                from tkinter import filedialog
                sp = filedialog.asksaveasfilename(
                    defaultextension=".xlsx", initialfile="Parties_Import_Template.xlsx",
                    filetypes=[("Excel","*.xlsx")])
                if not sp: return
                wb = openpyxl.Workbook(); ws = wb.active; ws.title = "Parties"
                hdrs   = ["Party Name","Type","Mobile","GSTIN","State","Email","Address"]
                sample = ["Ramesh Cloth Store","Supplier","9876543210","09ABCDE1234F1Z5","Uttar Pradesh","ramesh@email.com","Chowk, Lucknow"]
                hfill = PatternFill("solid",fgColor="1A365D")
                sfill = PatternFill("solid",fgColor="EBF8FF")
                bw    = Font(bold=True,color="FFFFFF",size=10)
                widths = [24,12,14,22,18,24,28]
                for i,(h,s,w) in enumerate(zip(hdrs,sample,widths),1):
                    hc = ws.cell(1,i,h); hc.font=bw; hc.fill=hfill
                    hc.alignment=Alignment(horizontal="center")
                    ws.cell(2,i,s).fill=sfill
                    ws.column_dimensions[hc.column_letter].width=w
                wb.save(sp)
                messagebox.showinfo("Template Ready",
                    f"Template save ho gaya!\n{sp}\n\n"
                    "Type: Customer / Supplier / Both\nRow 2 sample hai — delete karke apna data bharo.")
            except Exception as e:
                messagebox.showerror("Error",str(e))

        make_btn(bf,"📤 Excel se Import",import_parties_excel,bg="#2F855A").pack(side="left",padx=(0,4))
        make_btn(bf,"📋 Import Template Download",download_parties_template,bg="#744210").pack(side="left",padx=4)

        # ── Table — sabse neeche ──
        tbl=make_table(p,["Party Name","Type","Mobile","GSTIN","State","Address","Edit","Delete"],
                       [18,10,13,18,14,18,7,7])

        def refresh():
            clear_table_rows(tbl)
            conn=get_db()
            for i,pt in enumerate([dict(r) for r in conn.execute("SELECT * FROM parties ORDER BY name").fetchall()]):
                bg=C_WHITE if i%2==0 else "#F7FAFC"
                st = pt.get("state","") or ""
                for j,val in enumerate([pt["name"],pt["ptype"],pt["mobile"],
                                        pt["gstin"],st,pt["address"][:16],"",""]):
                    if j==6:
                        tk.Button(tbl,text="✏ Edit",font=("Segoe UI",8,"bold"),
                                  bg="#8B1A1A",fg=C_WHITE,relief="flat",cursor="hand2",bd=0,pady=3,
                                  command=lambda r=pt: load_edit(r)
                                  ).grid(row=i+1,column=j,sticky="nsew",padx=2,pady=1)
                    elif j==7:
                        tk.Button(tbl,text="🗑 Del",font=("Segoe UI",8,"bold"),
                                  bg=C_RED,fg=C_WHITE,relief="flat",cursor="hand2",bd=0,pady=3,
                                  command=lambda r=pt: delete_party(r)
                                  ).grid(row=i+1,column=j,sticky="nsew",padx=2,pady=1)
                    else:
                        tk.Label(tbl,text=str(val),font=("Segoe UI",9),
                                 bg=bg,fg=C_GRAY,anchor="w",padx=6,pady=4
                                 ).grid(row=i+1,column=j,sticky="nsew",padx=1)

        def load_edit(pt):
            edit_id[0]=pt["id"]
            pt_name.set(pt["name"]); pt_type.set(pt["ptype"])
            pt_mob.set(pt["mobile"]); pt_gst.set(pt["gstin"]); pt_addr.set(pt["address"])
            pt_state.set(pt.get("state","") or "Uttar Pradesh")
            pt_email.set(pt.get("email","") or "")
            save_btn.config(text="💾 Update Party", bg=C_AMBER)
            cancel_btn.pack(side="left",padx=4)

        def cancel_edit():
            edit_id[0]=None
            pt_name.set(""); pt_mob.set(""); pt_gst.set(""); pt_addr.set("")
            pt_type.set("Customer"); pt_state.set("Uttar Pradesh"); pt_email.set("")
            save_btn.config(text="+ Add Party", bg=C_ACCENT)
            cancel_btn.pack_forget()

        def save():
            name=pt_name.get().strip()
            if not name: messagebox.showerror("Error","Party naam bharo!"); return
            conn=get_db()
            try:
                if edit_id[0]:
                    conn.execute("UPDATE parties SET name=?,ptype=?,mobile=?,gstin=?,address=?,state=?,email=? WHERE id=?",
                                 (name,pt_type.get(),pt_mob.get(),pt_gst.get(),pt_addr.get(),
                                  pt_state.get(),pt_email.get().strip(),edit_id[0]))
                    conn.commit()
                    messagebox.showinfo("Done","Party update ho gayi!")
                    cancel_edit()
                else:
                    conn.execute("INSERT INTO parties(name,ptype,mobile,gstin,address,state,email) VALUES(?,?,?,?,?,?,?)",
                                 (name,pt_type.get(),pt_mob.get(),pt_gst.get(),pt_addr.get(),
                                  pt_state.get(),pt_email.get().strip()))
                    conn.commit()
                    messagebox.showinfo("Done","Party add ho gayi!")
                    pt_name.set(""); pt_mob.set(""); pt_gst.set(""); pt_addr.set("")
                    pt_state.set("Uttar Pradesh"); pt_email.set("")
                refresh()
            except sqlite3.IntegrityError:
                messagebox.showerror("Error","Party pehle se exist karti hai!")
            finally: conn.close()

        def delete_party(pt):
            if not messagebox.askyesno("Delete?",f"'{pt['name']}' delete karna chahte ho?"):
                return
            conn=get_db()
            conn.execute("DELETE FROM parties WHERE id=?", (pt["id"],))
            conn.commit(); conn.close()
            refresh()

        # save/cancel ko actual functions assign karo
        save_btn.config(command=save)
        cancel_btn.config(command=cancel_edit)

        refresh()

