        tk.Label(lr, text="Product:", **lbl_r).pack(side="left")
        v_rp = tk.StringVar()
        cb_rp = ttk.Combobox(lr, textvariable=v_rp, width=11); cb_rp.pack(side="left", padx=(2, 4))
        tk.Label(lr, text="Qty:", **lbl_r).pack(side="left")
        v_rq = tk.StringVar(value="1")
        ttk.Entry(lr, textvariable=v_rq, width=3).pack(side="left", padx=(2, 4))
        tk.Label(lr, text="Rate:", **lbl_r).pack(side="left")
        v_rrate = tk.StringVar()
        ttk.Entry(lr, textvariable=v_rrate, width=5).pack(side="left", padx=(2, 4))
        tk.Label(lr, text="GST%:", **lbl_r).pack(side="left")
        v_rgst = tk.StringVar(value="0")
        ttk.Combobox(lr, textvariable=v_rgst, values=["0","5","12","18","28"],
                     width=3, state="readonly").pack(side="left", padx=(2, 4))

        def add_ret():
            prod = v_rp.get().strip()
            if not prod: messagebox.showerror("Error","Product select karo!"); return
            try:
