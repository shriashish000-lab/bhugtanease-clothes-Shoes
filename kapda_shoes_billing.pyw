                    gst_f=float(it.get("gst_percent",it.get("gst",0)))
                    taxable=qty_f*rate_f
                    gst_amt=taxable*gst_f/100
                    tot=taxable+gst_amt
                except: gst_amt=0; tot=0

                ttk.Combobox(tbl_f,textvariable=prod_v,values=all_products,width=22,font=("Segoe UI",9)
                             ).grid(row=ri+1,column=0,sticky="ew",padx=1,pady=1)
                ttk.Entry(tbl_f,textvariable=qty_v,width=6,font=("Segoe UI",9)
                          ).grid(row=ri+1,column=1,sticky="ew",padx=1,pady=1)
                ttk.Entry(tbl_f,textvariable=rate_v,width=10,font=("Segoe UI",9)
                          ).grid(row=ri+1,column=2,sticky="ew",padx=1,pady=1)
