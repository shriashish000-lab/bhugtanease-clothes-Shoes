                data = [[r["damage_no"], r["damage_date"], r["product"], int(r["qty"]),
                         r["damage_type"], r["source"], r["ref_bill"],
                         r["description"], r["repair_cost"], r["status"],
                         r["resolution"], r["resolved_date"]] for r in rows]
                export_to_excel(
                    ["DMG No","Date","Product","Qty","Damage Type","Source","Ref Bill",
                     "Description","Repair Cost","Status","Resolution","Resolved Date"],
                    data, "Damage_Stock")
            except Exception as e:
