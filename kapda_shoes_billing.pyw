        rr2 = tk.Frame(rf, bg="#F0FFF4"); rr2.pack(fill="x", padx=8, pady=(0, 6))
        lbl_g = dict(font=("Segoe UI", 8, "bold"), bg="#F0FFF4", fg="#276749")
        tk.Label(rr2, text="Product:", **lbl_g).pack(side="left")
        v_np = tk.StringVar()
        cb_np = ttk.Combobox(rr2, textvariable=v_np, values=all_prods, width=11); cb_np.pack(side="left", padx=(2,4))
        tk.Label(rr2, text="Qty:", **lbl_g).pack(side="left")
        v_nq = tk.StringVar(value="1")
        ttk.Entry(rr2, textvariable=v_nq, width=3).pack(side="left", padx=(2,4))
        tk.Label(rr2, text="Rate:", **lbl_g).pack(side="left")
        v_nrate = tk.StringVar()
        ttk.Entry(rr2, textvariable=v_nrate, width=5).pack(side="left", padx=(2,4))
        tk.Label(rr2, text="GST%:", **lbl_g).pack(side="left")
        v_ngst = tk.StringVar(value="0")
        ttk.Combobox(rr2, textvariable=v_ngst, values=["0","5","12","18","28"],
                     width=3, state="readonly").pack(side="left", padx=(2,4))

        def add_new():
            prod = v_np.get().strip()
            if not prod: messagebox.showerror("Error","Product select karo!"); return
            try:
                q = float(v_nq.get()); r3 = float(v_nrate.get()); g = float(v_ngst.get()); assert q > 0
            except:
                messagebox.showerror("Error","Qty aur Rate sahi bharo!"); return
            tax = round(q*r3,2); ga = round(tax*g/100,2); tot = round(tax+ga,2)
            _new_items.append({"product":prod,"qty":q,"rate":r3,"gst_pct":g,"gst_amt":ga,"total_amt":tot})
            render_both()
            v_np.set(""); v_nq.set("1"); v_nrate.set(""); v_ngst.set("0")

        def clear_new_fields():
            v_np.set(""); v_nq.set("1"); v_nrate.set(""); v_ngst.set("0")

        make_btn(rr2, "+ Add", add_new, bg="#276749", font_size=8, padx=6, pady=3).pack(side="left", padx=(0,2))
        make_btn(rr2, "Clear", clear_new_fields, bg=C_GRAY, font_size=8, padx=6, pady=3).pack(side="left")

        new_tbl = make_table(rf, ["#","Product","Qty","Rate","Total","\u2715"],
                             [3,20,5,8,9,3])

        v_new_tot_lbl = tk.StringVar(value="Naya Total: \u20b90")
        tk.Label(rf, textvariable=v_new_tot_lbl, font=("Segoe UI", 10, "bold"),
