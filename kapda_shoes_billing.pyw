                conn=get_db()
                rows=conn.execute(
                    "SELECT * FROM returns WHERE return_type='sale_return' ORDER BY return_date DESC"
                ).fetchall()
                conn.close()
                data=[]
                for r in rows:
                    if frm and r["return_date"] < frm: continue
                    if to and r["return_date"] > to: continue
                    if q_txt and q_txt not in r["return_no"].lower() and \
                       q_txt not in r["party"].lower() and q_txt not in r["product"].lower():
                        continue
                    data.append([r["return_no"],fmt_date(r["return_date"]),r["orig_bill"],
                                 r["party"],r["product"],str(r["qty"]),f"{r['total_amt']:.2f}",r["reason"] or ""])
                export_to_excel(["Return No","Date","Orig Bill","Customer","Product","Qty","Total","Reason"],
                                data, "Sale_Return_History")
