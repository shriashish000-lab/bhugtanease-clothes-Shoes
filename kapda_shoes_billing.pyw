                row_w={}
                prod_v=tk.StringVar(value=it.get("product",""))
                qty_v =tk.StringVar(value=str(it.get("qty",0)))
                rate_v=tk.StringVar(value=str(it.get("rate",0)))
                gst_v =tk.StringVar(value=str(int(it.get("gst_percent",18))))

