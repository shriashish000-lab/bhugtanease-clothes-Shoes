                     ).grid(row=1,column=0,sticky="ew",padx=4,pady=(0,8))
        ttk.Entry(af,textvariable=n_qty,width=8,font=("Segoe UI",9)
                  ).grid(row=1,column=1,sticky="ew",padx=4,pady=(0,8))
        ttk.Entry(af,textvariable=n_rate,width=10,font=("Segoe UI",9)
                  ).grid(row=1,column=2,sticky="ew",padx=4,pady=(0,8))

        def add_new_item():
            if not n_prod.get(): messagebox.showerror("Error","Product select karo!",parent=win); return
            try: qty=float(n_qty.get()); rate=float(n_rate.get())
            except: messagebox.showerror("Error","Qty/Rate sahi bharo!",parent=win); return
            edit_items.append({"product":n_prod.get(),"qty":qty,"rate":rate,"total":qty*rate})
            n_prod.set(""); n_qty.set(""); n_rate.set("")
            render_items()

        make_btn(af,"+ Add",add_new_item,pady=5).grid(row=1,column=3,padx=8,pady=(0,8),sticky="ew")

        def collect_and_save():
            updated=[]
            for w in item_rows_widgets:
                try:
                    prod=w["prod"].get().strip()
                    qty=float(w["qty"].get())
                    rate=float(w["rate"].get())
                    gst=float(w["gst"].get())
                    taxable=qty*rate
                    gst_amt=taxable*gst/100
                    total=taxable+gst_amt
                    updated.append({"product":prod,"qty":qty,"rate":rate,
                                    "taxable":taxable,"gst":gst,"gst_amt":gst_amt,"total":total})
                except: pass
            if not updated:
                messagebox.showerror("Error","Koi item nahi!",parent=win); return
            grand=sum(it["total"] for it in updated)
            conn=get_db()
            try:
                conn.execute("UPDATE purchases SET bill_date=?,party=?,grand_total=?,pay_mode=?,due_date=? WHERE id=?",
                             (e_date.get(), e_party.get(), grand, e_paymode.get(), e_due.get().strip(), pid))
                conn.execute("DELETE FROM purchase_items WHERE purchase_id=?", (pid,))
                for it in updated:
                    conn.execute("INSERT INTO purchase_items(purchase_id,product,qty,rate,taxable,gst_percent,gst_amt,total) VALUES(?,?,?,?,?,?,?,?)",
                                 (pid,it["product"],it["qty"],it["rate"],it["taxable"],it["gst"],it["gst_amt"],it["total"]))
                    # ── Auto: products table sync ─────────────────────────────
                    pname = it["product"].strip()
                    ex = conn.execute("SELECT id FROM products WHERE name=?", (pname,)).fetchone()
                    if ex:
                        conn.execute("UPDATE products SET purchase_rate=?, gst_percent=? WHERE name=?",
                                     (it["rate"], it["gst"], pname))
                    else:
                        conn.execute("""INSERT OR IGNORE INTO products
                            (name,purchase_rate,sale_rate,gst_percent,opening_stock,
                             hsn,category,brand,product_type,
                             size_options,color_options,barcode,low_stock_alert)
                            VALUES(?,?,?,?,0,'','','','Clothes','','','',5)""",
                            (pname, it["rate"], round(it["rate"]*1.3,2), it["gst"]))
                conn.commit()
                messagebox.showinfo("Done","Purchase update ho gaya!",parent=win)
                win.destroy(); refresh_cb()
            except Exception as e:
                messagebox.showerror("Error",str(e),parent=win)
            finally: conn.close()

        bf2=tk.Frame(p,bg=C_BG); bf2.pack(fill="x",pady=10)
        make_btn(bf2,"💾 Save Changes",collect_and_save).pack(side="left",padx=(0,8))
        make_btn(bf2,"✕ Cancel",win.destroy,bg=C_GRAY).pack(side="left")

