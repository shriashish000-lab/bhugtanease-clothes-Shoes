        def _get_gdrive_service():
            """Google Drive service banao — credentials.json se OAuth2 flow chalao."""
            try:
                from google.oauth2.credentials import Credentials
                from google_auth_oauthlib.flow import InstalledAppFlow
                from google.auth.transport.requests import Request
                from googleapiclient.discovery import build
            except ImportError:
                messagebox.showerror("Library Missing",
                    "Google Drive ke liye ye libraries chahiye:\n\n"
                    "CMD mein chalao:\n"
                    "pip install google-auth google-auth-oauthlib google-auth-httplib2 google-api-python-client\n\n"
                    "Phir dobara try karo.")
                return None

            SCOPES = ["https://www.googleapis.com/auth/drive.file"]
            creds_file = os.path.join(os.path.dirname(DB_FILE), "gdrive_token.json")
            creds_json = os.path.join(os.path.dirname(DB_FILE), "credentials.json")
            creds = None

            if os.path.exists(creds_file):
                try:
                    creds = Credentials.from_authorized_user_file(creds_file, SCOPES)
                except Exception:
                    creds = None

            if not creds or not creds.valid:
                if creds and creds.expired and creds.refresh_token:
                    try:
                        creds.refresh(Request())
                    except Exception:
                        creds = None

                if not creds:
                    if not os.path.exists(creds_json):
                        messagebox.showinfo("Setup Required",
                            "Google Drive ke liye pehle setup karna hoga:\n\n"
                            "1. https://console.cloud.google.com pe jaao\n"
                            "2. New Project banao\n"
                            "3. Google Drive API enable karo\n"
                            "4. OAuth 2.0 Client ID banao (Desktop App)\n"
                            "5. credentials.json download karo\n"
                            f"6. Isko yahan rakho:\n   {creds_json}\n\n"
                            "Phir dobara try karo.")
                        return None
                    try:
                        flow = InstalledAppFlow.from_client_secrets_file(creds_json, SCOPES)
                        creds = flow.run_local_server(port=0)
                    except Exception as e:
                        messagebox.showerror("Auth Error", f"Google login fail:\n{str(e)}")
                        return None

                with open(creds_file, "w") as f:
                    f.write(creds.to_json())

            try:
                service = build("drive", "v3", credentials=creds)
                return service
            except Exception as e:
                messagebox.showerror("Drive Error", f"Drive connect nahi hua:\n{str(e)}")
                return None

        def do_gdrive_backup():
            """Database ko Google Drive mein backup karo."""
            import datetime as _dt
            bkp_status.config(text="⏳ Google Drive se connect ho raha hai...", fg=C_AMBER)
            pg.update()
            service = _get_gdrive_service()
            if not service:
                bkp_status.config(text="", fg=C_GRAY)
                return
            try:
                from googleapiclient.http import MediaFileUpload
                import sqlite3 as _sq, tempfile as _tmp

                # Temp file mein safe backup banao
                ts = _dt.datetime.now().strftime("%Y%m%d_%H%M%S")
                fname = f"BhugtanEase_Backup_{ts}.db"
                tmp_path = os.path.join(_tmp.gettempdir(), fname)
                sc = _sq.connect(DB_FILE); dc = _sq.connect(tmp_path)
                sc.backup(dc); sc.close(); dc.close()

                # BhugtanEase folder Drive mein dhundho ya banao
                folder_q = service.files().list(
                    q="name='BhugtanEase Backups' and mimeType='application/vnd.google-apps.folder' and trashed=false",
                    fields="files(id,name)").execute()
                folders = folder_q.get("files", [])
                if folders:
                    folder_id = folders[0]["id"]
                else:
                    folder_meta = {"name": "BhugtanEase Backups",
                                   "mimeType": "application/vnd.google-apps.folder"}
                    folder = service.files().create(body=folder_meta, fields="id").execute()
                    folder_id = folder["id"]

                # File upload
                media = MediaFileUpload(tmp_path, mimetype="application/octet-stream", resumable=True)
                file_meta = {"name": fname, "parents": [folder_id]}
                uploaded = service.files().create(body=file_meta, media_body=media, fields="id,name,size").execute()

                os.remove(tmp_path)
                size_kb = int(uploaded.get("size", 0)) // 1024
                bkp_status.config(
                    text=f"✅ Google Drive backup ho gaya! ({size_kb} KB)  📁 BhugtanEase Backups/{fname}",
                    fg="#276749")
                pg.after(10000, lambda: bkp_status.config(text=""))
                messagebox.showinfo("Google Drive Backup",
                    f"✅ Backup Google Drive mein save ho gaya!\n\n"
                    f"📁 Folder: BhugtanEase Backups\n"
                    f"📄 File: {fname}\n\n"
                    "Drive.google.com pe jaake dekh sakte hain.")
            except Exception as e:
                bkp_status.config(text=f"❌ Drive backup fail: {str(e)[:60]}", fg=C_RED)
                messagebox.showerror("Drive Backup Error", str(e))

        def do_gdrive_restore():
