_LIC_SECRET = "KapdaShoes@2025#VNS"
_EPOCH      = datetime.date(2024, 1, 1)

# ── Serial Engine v2 (Admin tool se compatible) ───────────────────────────────
def _b36dec(s):
    return int(s, 36)

def _name_hash(customer_name):
    normalized = customer_name.strip().upper().replace(" ", "")
    import hmac as _hmac
    h = _hmac.new(_LIC_SECRET.encode(), normalized.encode(), hashlib.sha256).hexdigest()
    return h[:4].upper()

def _sign6(data):
    import hmac as _hmac
    return _hmac.new(_LIC_SECRET.encode(), data.encode(), hashlib.sha256).hexdigest()[:6].upper()

def _verify_serial_v2(serial: str, customer_name: str):
    """
    Returns: (valid: bool, expiry: date or None, days_left: int)
    Serial format: KS-{expiry_b36}-{name_hash4}-{sign6}
    """
    serial = serial.strip().upper()
    parts  = serial.split("-")
    if len(parts) != 4 or parts[0] != "KS":
        return False, None, 0
    expiry_b36, name_h, sign = parts[1], parts[2], parts[3]
    body = expiry_b36 + name_h
    if _sign6(body) != sign:
        return False, None, 0
    if _name_hash(customer_name) != name_h:
        return False, None, 0
    try:
        expiry    = _EPOCH + datetime.timedelta(days=_b36dec(expiry_b36))
        days_left = (expiry - datetime.date.today()).days
        return True, expiry, days_left
    except Exception:
        return False, None, 0

def _get_license_info():
    """
    Returns: (status, days_left, expiry_str, customer_name)
    status: 'new'     → Pehli baar — serial required
            'ok'      → Active license
            'expired' → Expire ho gayi — serial required
    """
    try:
        conn = sqlite3.connect(DB_FILE)
        rows = {r[0]: r[1] for r in conn.execute(
            "SELECT key,value FROM settings WHERE key IN "
            "('license_expiry','license_customer','license_serial','license_days')"
        ).fetchall()}
        conn.close()

        expiry_str = rows.get('license_expiry', '').strip()
        customer   = rows.get('license_customer', '').strip()
        serial     = rows.get('license_serial', '').strip()

        # Pehli baar — koi bhi license record nahi
        if not expiry_str or not serial:
            return ('new', 0, '', customer)

        expiry_date = datetime.date.fromisoformat(expiry_str)
        today       = datetime.date.today()
        days_left   = (expiry_date - today).days

        if today > expiry_date:
            return ('expired', days_left, expiry_str, customer)
        return ('ok', days_left, expiry_str, customer)
    except Exception:
        return ('new', 0, '', '')

def _activate_license(serial: str, customer_name: str = "") -> bool:
    """Renewal: customer naam (naya ya stored) se serial verify karo"""
    if not customer_name:
        try:
            conn = sqlite3.connect(DB_FILE)
            row  = conn.execute("SELECT value FROM settings WHERE key='license_customer'").fetchone()
            conn.close()
            customer_name = row[0].strip() if row else ""
        except:
            customer_name = ""
    if not customer_name:
        return False
    valid, expiry, days_left = _verify_serial_v2(serial, customer_name)
    if valid and days_left >= 0:
        try:
            conn = sqlite3.connect(DB_FILE)
            for k, v in [
                ('license_customer', customer_name.upper()),
                ('license_expiry',   expiry.isoformat()),
                ('license_serial',   serial.strip().upper()),
                ('install_date',     datetime.date.today().isoformat()),
            ]:
                conn.execute("INSERT OR REPLACE INTO settings(key,value) VALUES(?,?)", (k, v))
            conn.commit()
            conn.close()
            return True
        except:
            pass
    return False

def _activate_license_with_name(serial: str, customer_name: str) -> bool:
    """Pehli activation: customer naam + serial verify karke DB mein save karo"""
    serial        = serial.strip().upper()
    customer_name = customer_name.strip()
    if not customer_name or not serial:
        return False
    valid, expiry, days_left = _verify_serial_v2(serial, customer_name)
    if valid and days_left >= 0:
        try:
            conn = sqlite3.connect(DB_FILE)
            for k, v in [
                ('license_customer', customer_name.upper()),
                ('license_expiry',   expiry.isoformat()),
                ('license_serial',   serial),
                ('install_date',     datetime.date.today().isoformat()),
            ]:
                conn.execute("INSERT OR REPLACE INTO settings(key,value) VALUES(?,?)", (k, v))
            conn.commit()
            conn.close()
            return True
        except:
            pass
    return False

