        tk.Label(diff_f, textvariable=v_diff_lbl, font=("Segoe UI", 12, "bold"),
                 bg="#EBF8FF", fg="#8B1A1A").pack(side="left", padx=16, pady=8)
        tk.Label(diff_f, text="Payment Mode:", font=("Segoe UI", 9), bg="#EBF8FF", fg=C_GRAY).pack(side="left", padx=(20,4))
        v_pay_mode = tk.StringVar(value="Cash")
        ttk.Combobox(diff_f, textvariable=v_pay_mode,
                     values=["Cash","UPI","Card","Bank Transfer","Credit"],
                     width=14, state="readonly").pack(side="left")

        def render_both():
            # Render return table
            clear_table_rows(ret_tbl)
            ret_grand = 0
            for i, it in enumerate(_ret_items):
                ret_grand += it["total_amt"]
                bg = C_WHITE if i%2==0 else "#FFF5F5"
                vals = [i+1, it["product"][:18], it["qty"], f"\u20b9{it['rate']:.0f}", f"\u20b9{it['total_amt']:.0f}", ""]
                for j, val in enumerate(vals):
                    if j == 5:
                        tk.Button(ret_tbl, text="\u2715", font=("Segoe UI",8),
                                  bg=bg, fg=C_RED, relief="flat", cursor="hand2", bd=0,
                                  command=lambda idx=i: (_ret_items.pop(idx), render_both())
                                  ).grid(row=i+1, column=j, sticky="nsew", padx=1)
                    else:
                        tk.Label(ret_tbl, text=str(val), font=("Segoe UI",8),
                                 bg=bg, fg=C_GRAY, anchor="w", padx=4, pady=3
                                 ).grid(row=i+1, column=j, sticky="nsew", padx=1)
            v_ret_tot_lbl.set(f"Wapas Total: \u20b9{ret_grand:,.0f}  ({len(_ret_items)} items)")

            # Render new table
            clear_table_rows(new_tbl)
            new_grand = 0
            for i, it in enumerate(_new_items):
                new_grand += it["total_amt"]
                bg = C_WHITE if i%2==0 else "#F0FFF4"
                vals = [i+1, it["product"][:18], it["qty"], f"\u20b9{it['rate']:.0f}", f"\u20b9{it['total_amt']:.0f}", ""]
                for j, val in enumerate(vals):
                    if j == 5:
                        tk.Button(new_tbl, text="\u2715", font=("Segoe UI",8),
                                  bg=bg, fg=C_RED, relief="flat", cursor="hand2", bd=0,
                                  command=lambda idx=i: (_new_items.pop(idx), render_both())
                                  ).grid(row=i+1, column=j, sticky="nsew", padx=1)
                    else:
                        tk.Label(new_tbl, text=str(val), font=("Segoe UI",8),
                                 bg=bg, fg=C_GRAY, anchor="w", padx=4, pady=3
                                 ).grid(row=i+1, column=j, sticky="nsew", padx=1)
            v_new_tot_lbl.set(f"Naya Total: \u20b9{new_grand:,.0f}  ({len(_new_items)} items)")

            # Diff
            diff = round(new_grand - ret_grand, 2)
            if diff > 0:
                v_diff_lbl.set(f"Customer ko DENA hoga: \u20b9{diff:,.2f}  (Naye products zyada mahange)")
            elif diff < 0:
                v_diff_lbl.set(f"Customer ko WAPAS MILEGA: \u20b9{abs(diff):,.2f}  (Naye products saste)")
            else:
                v_diff_lbl.set("Fark: \u20b90.00  \u2014 Bilkul barabar exchange")

        def on_bill_select(ev=None):
            bn = v_bill.get().strip()
            if not bn: return
            d = get_db()
            row = d.execute("SELECT party FROM sales WHERE bill_no=?", (bn,)).fetchone()
            prods = [x[0] for x in d.execute(
                "SELECT DISTINCT si.product FROM sale_items si "
                "JOIN sales s ON si.sale_id=s.id WHERE s.bill_no=?", (bn,)).fetchall()]
            d.close()
            if row:
                e_party.config(state="normal"); v_party.set(row["party"]); e_party.config(state="readonly")
            cb_rp["values"] = prods
            _ret_items.clear(); _new_items.clear(); render_both()

        def on_ret_prod(ev=None):
            bn = v_bill.get().strip(); pr = v_rp.get().strip()
            if not bn or not pr: return
            d = get_db()
            row = d.execute(
                "SELECT si.rate, si.gst_percent FROM sale_items si "
                "JOIN sales s ON si.sale_id=s.id WHERE s.bill_no=? AND si.product=? LIMIT 1",
                (bn, pr)).fetchone()
            d.close()
            if row: v_rrate.set(str(round(row["rate"],2))); v_rgst.set(str(round(row["gst_percent"],1)))

        def on_new_prod(ev=None):
            pr = v_np.get().strip()
            if not pr: return
            d = get_db()
            row = d.execute("SELECT sale_price, gst_percent FROM products WHERE name=? LIMIT 1", (pr,)).fetchone()
            d.close()
            if row:
                v_nrate.set(str(round(row["sale_price"] if row["sale_price"] else 0, 2)))
                v_ngst.set(str(round(row["gst_percent"] if row["gst_percent"] else 0, 1)))

        cb_bill.bind("<<ComboboxSelected>>", on_bill_select)
        cb_rp.bind("<<ComboboxSelected>>", on_ret_prod)
        cb_np.bind("<<ComboboxSelected>>", on_new_prod)

        def do_save():
            if not _ret_items: messagebox.showerror("Error","Wapas aane wala koi item nahi!"); return
            if not _new_items: messagebox.showerror("Error","Naya koi item nahi!"); return
            bill  = v_bill.get().strip(); party = v_party.get().strip()
            if not bill or not party: messagebox.showerror("Error","Sale Bill aur Customer zaroori!"); return

            ret_grand = sum(it["total_amt"] for it in _ret_items)
            new_grand = sum(it["total_amt"] for it in _new_items)
            diff = round(new_grand - ret_grand, 2)

            d = get_db()
            n    = d.execute("SELECT COUNT(*) FROM exchanges").fetchone()[0]
            exno = "EX-{:03d}".format(n+1)
            d.execute(
                "INSERT INTO exchanges(exchange_no,exchange_date,orig_bill,party,"
                "diff_amount,payment_mode,reason) VALUES(?,?,?,?,?,?,?)",
                (exno, v_date.get(), bill, party, diff, v_pay_mode.get(), v_reason.get().strip()))
            for it in _ret_items:
                d.execute(
                    "INSERT INTO exchange_return_items(exchange_no,product,qty,rate,gst_pct,gst_amt,total_amt) "
                    "VALUES(?,?,?,?,?,?,?)",
                    (exno, it["product"], it["qty"], it["rate"], it["gst_pct"], it["gst_amt"], it["total_amt"]))
                d.execute("UPDATE products SET opening_stock=opening_stock+? WHERE name=?",
                          (it["qty"], it["product"]))
            for it in _new_items:
                d.execute(
                    "INSERT INTO exchange_new_items(exchange_no,product,qty,rate,gst_pct,gst_amt,total_amt) "
                    "VALUES(?,?,?,?,?,?,?)",
                    (exno, it["product"], it["qty"], it["rate"], it["gst_pct"], it["gst_amt"], it["total_amt"]))
                d.execute("UPDATE products SET opening_stock=MAX(0,opening_stock-?) WHERE name=?",
                          (it["qty"], it["product"]))
            d.commit(); d.close()

            _show_exchange_slip(exno, bill, party, _ret_items[:], _new_items[:],
                                ret_grand, new_grand, diff, v_pay_mode.get(), v_reason.get(), v_date.get())
            _ret_items.clear(); _new_items.clear(); render_both()
            v_bill.set(""); e_party.config(state="normal"); v_party.set(""); e_party.config(state="readonly")
            v_reason.set("")
            load_hist()

        def _show_exchange_slip(exno, orig_bill, party, ret_its, new_its,
                                 ret_grand, new_grand, diff, pay_mode, reason, ex_date):
            win = tk.Toplevel(); win.title(f"Exchange Slip \u2014 {exno}")
            win.configure(bg=C_WHITE); win.geometry("580x600"); win.grab_set()
            tk.Frame(win, bg="#8B1A1A", height=6).pack(fill="x")
            tk.Label(win, text="\U0001f504  EXCHANGE SLIP", font=("Segoe UI",16,"bold"),
                     bg=C_WHITE, fg="#8B1A1A").pack(pady=(12,2))
            tk.Label(win, text=f"Exchange No: {exno}   |   Date: {ex_date}",
                     font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack()
            tk.Label(win, text=f"Customer: {party}   |   Original Bill: {orig_bill}",
                     font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack()
            if reason:
                tk.Label(win, text=f"Reason: {reason}", font=("Segoe UI",9,"italic"),
                         bg=C_WHITE, fg=C_GRAY).pack()
            tk.Frame(win, bg=C_BORDER, height=1).pack(fill="x", padx=20, pady=6)

            tk.Label(win, text="\u21a9  WAPAS AAYA", font=("Segoe UI",10,"bold"),
                     bg=C_WHITE, fg=C_RED).pack(anchor="w", padx=20)
            for it in ret_its:
                tk.Label(win, text=f"  \u2022 {it['product']}  Qty:{it['qty']}  Rate:\u20b9{it['rate']:.0f}  Total:\u20b9{it['total_amt']:.0f}",
                         font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(anchor="w", padx=30)
            tk.Label(win, text=f"  Wapas Total: \u20b9{ret_grand:,.0f}",
                     font=("Segoe UI",10,"bold"), bg=C_WHITE, fg=C_RED).pack(anchor="w", padx=20, pady=(2,6))

            tk.Frame(win, bg=C_BORDER, height=1).pack(fill="x", padx=20, pady=4)
            tk.Label(win, text="\u2705  NAYA DIYA", font=("Segoe UI",10,"bold"),
                     bg=C_WHITE, fg="#276749").pack(anchor="w", padx=20)
            for it in new_its:
                tk.Label(win, text=f"  \u2022 {it['product']}  Qty:{it['qty']}  Rate:\u20b9{it['rate']:.0f}  Total:\u20b9{it['total_amt']:.0f}",
                         font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(anchor="w", padx=30)
            tk.Label(win, text=f"  Naya Total: \u20b9{new_grand:,.0f}",
                     font=("Segoe UI",10,"bold"), bg=C_WHITE, fg="#276749").pack(anchor="w", padx=20, pady=(2,6))

            tk.Frame(win, bg=C_BORDER, height=1).pack(fill="x", padx=20, pady=6)
            if diff > 0:
                dt = f"Customer ne DIYA: \u20b9{diff:,.2f}  ({pay_mode})"; dc = "#276749"
            elif diff < 0:
                dt = f"Customer ko WAPAS DIYA: \u20b9{abs(diff):,.2f}  ({pay_mode})"; dc = C_RED
            else:
                dt = "Koi extra payment nahi \u2014 Barabar exchange"; dc = "#8B1A1A"
            tk.Label(win, text=dt, font=("Segoe UI",12,"bold"), bg=C_WHITE, fg=dc).pack(pady=8)
            tk.Frame(win, bg="#8B1A1A", height=4).pack(fill="x", side="bottom")
            make_btn(win, "\u274c  Close", win.destroy, bg=C_RED).pack(pady=8, side="bottom")

        # ── Action buttons ──
        btn_row = tk.Frame(p, bg=C_BG); btn_row.pack(fill="x", pady=6)
        make_btn(btn_row, "\U0001f4be  Save & Exchange Slip", do_save, bg="#8B1A1A").pack(side="left", padx=4)
        make_btn(btn_row, "\U0001f504  Clear All",
                 lambda: [_ret_items.clear(), _new_items.clear(), render_both(),
                          v_bill.set(""), v_reason.set("")],
                 bg=C_AMBER).pack(side="left", padx=4)

        # ── Exchange History ──
        tk.Label(p, text="Exchange History", font=("Segoe UI",11,"bold"),
                 bg=C_BG, fg=C_GRAY).pack(anchor="w", pady=(14,4))
        hist_tbl = make_table(p,
            ["EX No","Date","Bill","Customer","Wapas Items","Naye Items","Fark","Mode","\U0001f441"],
            [8, 10, 10, 16, 12, 12, 10, 8, 4])

        def load_hist():
            clear_table_rows(hist_tbl)
            d = get_db()
            rows = d.execute("SELECT * FROM exchanges ORDER BY exchange_date DESC LIMIT 100").fetchall()
            d.close()
            for i, r in enumerate(rows):
                bg = C_WHITE if i%2==0 else "#EBF8FF"
                diff_val = r["diff_amount"]
                diff_str = (f"+\u20b9{diff_val:,.0f}" if diff_val>0
                            else (f"-\u20b9{abs(diff_val):,.0f}" if diff_val<0 else "\u20b90"))
                d2 = get_db()
                ri_count = d2.execute("SELECT COUNT(*) FROM exchange_return_items WHERE exchange_no=?",
                                      (r["exchange_no"],)).fetchone()[0]
                ni_count = d2.execute("SELECT COUNT(*) FROM exchange_new_items WHERE exchange_no=?",
                                      (r["exchange_no"],)).fetchone()[0]
                d2.close()
                vals = [r["exchange_no"], r["exchange_date"], r["orig_bill"], r["party"],
                        f"{ri_count} item(s)", f"{ni_count} item(s)", diff_str, r["payment_mode"], ""]
                for j, val in enumerate(vals):
                    if j == 8:
                        rx = dict(r)
                        tk.Button(hist_tbl, text="\U0001f441", font=("Segoe UI",9),
                                  bg=bg, fg="#8B1A1A", relief="flat", cursor="hand2", bd=0,
                                  command=lambda rx=rx: _view_slip(rx["exchange_no"])
                                  ).grid(row=i+1, column=j, sticky="nsew", padx=1)
                    else:
                        tk.Label(hist_tbl, text=str(val), font=("Segoe UI",9),
                                 bg=bg, fg=C_GRAY, anchor="w", padx=6, pady=4
                                 ).grid(row=i+1, column=j, sticky="nsew", padx=1)

        def _view_slip(exno):
            d = get_db()
            ex  = d.execute("SELECT * FROM exchanges WHERE exchange_no=?", (exno,)).fetchone()
            ris = d.execute("SELECT * FROM exchange_return_items WHERE exchange_no=?", (exno,)).fetchall()
            nis = d.execute("SELECT * FROM exchange_new_items WHERE exchange_no=?", (exno,)).fetchall()
            d.close()
            if not ex: return
            ret_its = [{"product":r["product"],"qty":r["qty"],"rate":r["rate"],
                        "gst_pct":r["gst_pct"],"gst_amt":r["gst_amt"],"total_amt":r["total_amt"]} for r in ris]
            new_its = [{"product":r["product"],"qty":r["qty"],"rate":r["rate"],
                        "gst_pct":r["gst_pct"],"gst_amt":r["gst_amt"],"total_amt":r["total_amt"]} for r in nis]
            ret_g = sum(x["total_amt"] for x in ret_its)
            new_g = sum(x["total_amt"] for x in new_its)
            _show_exchange_slip(ex["exchange_no"], ex["orig_bill"], ex["party"],
                                ret_its, new_its, ret_g, new_g, ex["diff_amount"],
                                ex["payment_mode"], ex["reason"] or "", ex["exchange_date"])

        load_hist()

