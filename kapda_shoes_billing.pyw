                     bg=C_WHITE, fg=C_LGRAY, wraplength=500, justify="left").pack(anchor="w", pady=4)
            tk.Frame(paper, bg="#276749", height=2).pack(fill="x", pady=4)
            tk.Label(paper, text="Authorized Signatory", font=("Arial",9), bg=C_WHITE, fg=C_LGRAY).pack(anchor="e", padx=20)

        def _print_return_pdf(rno, orig_bill, party, items, ret_date, grand, reason, rtype):
            try:
                from reportlab.lib.pagesizes import A4
                from reportlab.lib import colors
                from reportlab.lib.units import mm
                from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer
                from reportlab.lib.styles import ParagraphStyle
                from reportlab.lib.enums import TA_CENTER, TA_RIGHT, TA_LEFT
                from tkinter import filedialog
                import os, sys

                save_path = filedialog.asksaveasfilename(
                    defaultextension=".pdf", filetypes=[("PDF","*.pdf")],
                    initialfile=f"{rno}.pdf", title="Return Bill PDF save karo")
                if not save_path: return
                _sp = get_shop()
                PAGE_W = 190*mm; BDR = colors.black
                GRN = colors.HexColor("#276749")

                def ps(nm, sz=9, bold=False, align=TA_LEFT):
                    return ParagraphStyle(nm, fontSize=sz,
                        fontName="Helvetica-Bold" if bold else "Helvetica",
                        alignment=align, leading=sz+3)

                BASE = [("BOX",(0,0),(-1,-1),0.5,BDR),("INNERGRID",(0,0),(-1,-1),0.3,BDR),
                        ("TOPPADDING",(0,0),(-1,-1),3),("BOTTOMPADDING",(0,0),(-1,-1),3),
                        ("LEFTPADDING",(0,0),(-1,-1),3),("RIGHTPADDING",(0,0),(-1,-1),3)]

                doc = SimpleDocTemplate(save_path, pagesize=A4,
                    leftMargin=12*mm, rightMargin=12*mm, topMargin=10*mm, bottomMargin=10*mm)
                story = []
                story.append(Table([[Paragraph(rtype.upper(), ps("t",13,True,TA_CENTER))]],
                    [PAGE_W], [("BOX",(0,0),(-1,-1),1,GRN),("BACKGROUND",(0,0),(-1,-1),GRN),
                               ("TEXTCOLOR",(0,0),(-1,-1),colors.white),
                               ("TOPPADDING",(0,0),(-1,-1),6),("BOTTOMPADDING",(0,0),(-1,-1),6)]))
                story.append(Spacer(1,2*mm))
                shop_txt = (f"<b>{_sp['name']}</b><br/>"
                    + (f"{_sp['address']}, {_sp['city']}<br/>" if _sp['address'] else "")
                    + (f"Mob: {_sp['mobile']}<br/>" if _sp['mobile'] else "")
                    + (f"GSTIN: {_sp['gstin']}" if _sp['gstin'] else ""))
                bill_info = (f"<b>Return No:</b> {rno}<br/>"
                    f"<b>Date:</b> {fmt_date(ret_date)}<br/>"
                    f"<b>Against Bill:</b> {orig_bill}<br/>"
                    f"<b>Supplier:</b> {party}"
                    + (f"<br/><b>Reason:</b> {reason}" if reason else ""))
                story.append(Table([[Paragraph(shop_txt,ps("sh",9)),Paragraph(bill_info,ps("bi",9))]],
                    [110*mm,80*mm], BASE))
                hdr = [Paragraph(x,ps("h",8,True,TA_CENTER)) for x in
                       ["Sl","Product","Qty","Rate(₹)","GST%","GST Amt","Total(₹)"]]
                rows = [hdr]; total_gst_sum = 0
                for i,it in enumerate(items,1):
                    total_gst_sum += it["gst_amt"]
                    rows.append([Paragraph(str(i),ps("r",8,align=TA_CENTER)),
                        Paragraph(it["product"],ps("r",8)),
                        Paragraph(str(it["qty"]),ps("r",8,align=TA_CENTER)),
                        Paragraph(f"{it['rate']:.2f}",ps("r",8,align=TA_RIGHT)),
                        Paragraph(f"{it['gst_percent']}%",ps("r",8,align=TA_CENTER)),
                        Paragraph(f"{it['gst_amt']:.2f}",ps("r",8,align=TA_RIGHT)),
                        Paragraph(f"{it['total_amt']:.2f}",ps("r",8,align=TA_RIGHT))])
                rows.append([Paragraph(""),Paragraph("<b>Total</b>",ps("r",9,True)),
                    Paragraph(""),Paragraph(""),Paragraph(""),
                    Paragraph(f"<b>{total_gst_sum:.2f}</b>",ps("r",9,True,TA_RIGHT)),
                    Paragraph(f"<b>{grand:.2f}</b>",ps("r",9,True,TA_RIGHT))])
                story.append(Spacer(1,3*mm))
                story.append(Table(rows,[10*mm,70*mm,18*mm,22*mm,14*mm,22*mm,24*mm],
                    BASE+[("BACKGROUND",(0,0),(-1,0),colors.HexColor("#FDEBD0")),
                          ("BACKGROUND",(0,-1),(-1,-1),colors.HexColor("#F0FFF4"))]))
                story.append(Spacer(1,2*mm))
                story.append(Table([[Paragraph(f"Amount: <b>{num_to_words(grand)}</b>",ps("aw",8))],
                    [Paragraph(f"Reason: {reason}" if reason else "",ps("aw",8))]],[PAGE_W],BASE))
                story.append(Spacer(1,4*mm))
                story.append(Table([[Paragraph(""),
                    Paragraph(f"For {_sp['name']}<br/><br/><br/>Authorized Signatory",
                               ps("sg",9,align=TA_RIGHT))]],
                    [110*mm,80*mm],BASE+[("BOTTOMPADDING",(0,0),(-1,-1),18)]))
                doc.build(story)
                if sys.platform=="win32": os.startfile(save_path)
                elif sys.platform=="darwin": __import__("subprocess").Popen(["open",save_path])
                else: __import__("subprocess").Popen(["xdg-open",save_path])
                messagebox.showinfo("PDF Ready!",f"Return Bill PDF save ho gayi:\n{save_path}")
            except ImportError:
                messagebox.showerror("Library Missing","reportlab install nahi hai.\n\nCMD mein chalao:\npip install reportlab")
            except Exception as e:
                messagebox.showerror("Error",f"PDF nahi ban saki:\n{str(e)}")

        bf = tk.Frame(p, bg=C_BG); bf.pack(fill="x", pady=6)
        make_btn(bf,"💾 Save & Print Return Bill", do_save_and_bill, bg=C_GREEN).pack(side="left", padx=(0,8))
        make_btn(bf,"🗑️ Clear Items",
                 lambda: [_return_items.clear(), render_items()], bg=C_GRAY).pack(side="left")

        divider(p)
        make_label(p, "📋  Purchase Return History", 11, True, color="#5C1A1A").pack(anchor="w", pady=(4,6))
        hf = tk.Frame(p, bg=C_BG); hf.pack(fill="x", pady=(0,4))
        tk.Label(hf,text="Search:",font=("Segoe UI",9),bg=C_BG,fg=C_GRAY).pack(side="left")
        v_search = tk.StringVar()
        ttk.Entry(hf,textvariable=v_search,width=22).pack(side="left",padx=6)
        make_btn(hf,"🔍 Filter",lambda:load_hist(),bg="#2B6CB0").pack(side="left",padx=4)

        tbl = make_table(p,
            ["Return No","Date","Orig Bill","Supplier","Product","Qty","Total","Reason","Bill"],
            [11,11,12,16,18,6,10,14,6])

        def load_hist():
            clear_table_rows(tbl)
            q_txt = v_search.get().lower()
            d = get_db()
            rows = d.execute(
                "SELECT * FROM returns WHERE return_type='pur_return' ORDER BY return_date DESC"
            ).fetchall()
            d.close()
            ri = 0
            for r in rows:
                if q_txt and q_txt not in r["return_no"].lower() and \
                   q_txt not in r["party"].lower() and q_txt not in r["product"].lower():
                    continue
                bg = C_WHITE if ri%2==0 else "#F0FFF4"
                rno = r["return_no"]
                for j, val in enumerate([r["return_no"], fmt_date(r["return_date"]),
                    r["orig_bill"], r["party"][:14], r["product"][:16],
                    str(r["qty"]), f"₹{int(r['total_amt'])}", (r["reason"] or "")[:12], ""]):
                    if j == 8:
                        tk.Button(tbl, text="📄", font=("Segoe UI",9),
                                  bg=C_GREEN, fg="white", relief="flat", cursor="hand2",
                                  command=lambda rn=rno: _view_return_bill(rn)
                                  ).grid(row=ri+1, column=j, sticky="nsew", padx=2, pady=2)
                    else:
                        tk.Label(tbl, text=str(val), font=("Segoe UI",9),
                                 bg=bg, fg=C_GRAY, anchor="w", padx=5, pady=4
                                 ).grid(row=ri+1, column=j, sticky="nsew", padx=1)
                ri += 1

        def _view_return_bill(rno):
            d = get_db()
            rows = d.execute("SELECT * FROM returns WHERE return_no=?", (rno,)).fetchall()
            d.close()
            if not rows: return
            items = [{"product":r["product"],"qty":r["qty"],"rate":r["rate"],
                      "gst_percent":r["gst_percent"],"gst_amt":r["gst_amt"],"total_amt":r["total_amt"]}
                     for r in rows]
            grand = sum(r["total_amt"] for r in rows)
            _show_return_bill(rows[0]["return_no"], rows[0]["orig_bill"],
                              rows[0]["party"], items,
                              rows[0]["return_date"], grand,
                              rows[0]["reason"] or "", "Purchase Return")

        load_hist()

    def _pg_exchange(self):
        """Exchange — Ek se zyada products wapas, ek se zyada naye products de."""
        import datetime as _dt
        db = get_db()
        db.execute("""CREATE TABLE IF NOT EXISTS exchanges (
            id              INTEGER PRIMARY KEY AUTOINCREMENT,
            exchange_no     TEXT UNIQUE NOT NULL,
            exchange_date   TEXT NOT NULL,
            orig_bill       TEXT NOT NULL,
            party           TEXT NOT NULL,
            diff_amount     REAL DEFAULT 0,
            payment_mode    TEXT DEFAULT 'Cash',
            reason          TEXT DEFAULT '',
            created_at      TEXT DEFAULT CURRENT_TIMESTAMP)""")
        db.execute("""CREATE TABLE IF NOT EXISTS exchange_return_items (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            exchange_no TEXT NOT NULL,
            product     TEXT NOT NULL,
            qty         REAL DEFAULT 0,
            rate        REAL DEFAULT 0,
            gst_pct     REAL DEFAULT 0,
            gst_amt     REAL DEFAULT 0,
            total_amt   REAL DEFAULT 0)""")
        db.execute("""CREATE TABLE IF NOT EXISTS exchange_new_items (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            exchange_no TEXT NOT NULL,
            product     TEXT NOT NULL,
            qty         REAL DEFAULT 0,
            rate        REAL DEFAULT 0,
            gst_pct     REAL DEFAULT 0,
            gst_amt     REAL DEFAULT 0,
            total_amt   REAL DEFAULT 0)""")
        db.commit(); db.close()

        _ret_items = []   # wapas aane wale
        _new_items = []   # naye jane wale

