        sh_search = tk.StringVar()
        ttk.Entry(ff,textvariable=sh_search,width=22,font=("Segoe UI",10)).pack(side="left",padx=4)

        tbl = make_table(p,
            ["EX No","Date","Bill","Customer","Wapas Items","Naye Items","Fark","Mode","View"],
            [8, 10, 10, 16, 12, 12, 10, 8, 5])

        tot_f = tk.Frame(p,bg=C_WHITE,highlightthickness=1,highlightbackground=C_BORDER)
