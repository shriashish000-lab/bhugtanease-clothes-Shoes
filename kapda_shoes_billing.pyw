                pick_win.configure(bg=C_WHITE)
                pick_win.grab_set()

                tk.Label(pick_win, text="🔽  Konsa backup restore karein?",
                         font=("Segoe UI",11,"bold"), bg=C_WHITE, fg="#8B1A1A").pack(pady=(16,8))
                tk.Label(pick_win, text="(Sabse upar = sabse naya backup)",
                         font=("Segoe UI",8,"italic"), bg=C_WHITE, fg=C_LGRAY).pack(pady=(0,8))

                listbox = tk.Listbox(pick_win, font=("Courier New", 9),
                                     selectmode="single", activestyle="dotbox",
                                     bg=C_WHITE, fg=C_GRAY, width=64, height=12)
                listbox.pack(padx=16, fill="both", expand=True)
                for f in drive_files:
                    sz = int(f.get("size", 0)) // 1024
                    listbox.insert(tk.END, f"  {f['name']}  ({sz} KB)")
                listbox.select_set(0)

                chosen_id = [None]

                def on_restore():
                    sel = listbox.curselection()
                    if not sel:
                        messagebox.showwarning("Select Karo", "Pehle ek backup file select karo.")
                        return
                    chosen_id[0] = drive_files[sel[0]]["id"]
                    pick_win.destroy()

                btn_f = tk.Frame(pick_win, bg=C_WHITE)
                btn_f.pack(pady=10)
                make_btn(btn_f, "📥 Isko Restore Karo", on_restore, bg="#8B1A1A").pack(side="left", padx=8)
                make_btn(btn_f, "Cancel", pick_win.destroy, bg=C_GRAY).pack(side="left")
                pick_win.wait_window()

                if not chosen_id[0]:
                    bkp_status.config(text="", fg=C_GRAY)
                    return

                bkp_status.config(text="⏳ Drive se download ho raha hai...", fg=C_AMBER)
                pg.update()

                # Download
                request = service.files().get_media(fileId=chosen_id[0])
                buf = io.BytesIO()
                dl = MediaIoBaseDownload(buf, request)
                done = False
                while not done:
                    _, done = dl.next_chunk()
                buf.seek(0)

                # Temp file mein save karo
                tmp_path = os.path.join(_tmp.gettempdir(), "gdrive_restore_tmp.db")
                with open(tmp_path, "wb") as f:
                    f.write(buf.read())

                # Verify
                test = _sq.connect(tmp_path)
                tables = [t[0] for t in test.execute("SELECT name FROM sqlite_master WHERE type='table'").fetchall()]
                test.close()
                if "products" not in tables and "parties" not in tables:
                    os.remove(tmp_path)
                    messagebox.showerror("Invalid File", "Drive pe jo file mili woh valid backup nahi lagti!")
                    bkp_status.config(text="", fg=C_GRAY)
                    return

                # Auto-backup current data before restore
                import datetime as _dt2
                ts2 = _dt2.datetime.now().strftime("%Y%m%d_%H%M%S")
                auto_bkp = DB_FILE.replace(".db", f"_before_gdrive_restore_{ts2}.db")
                try:
                    sc2 = _sq.connect(DB_FILE); dc2 = _sq.connect(auto_bkp)
                    sc2.backup(dc2); sc2.close(); dc2.close()
                except: pass

                sc3 = _sq.connect(tmp_path); dc3 = _sq.connect(DB_FILE)
                sc3.backup(dc3); sc3.close(); dc3.close()
                os.remove(tmp_path)

                bkp_status.config(text="✅ Google Drive se restore ho gaya! Software restart karein.", fg="#276749")
                messagebox.showinfo("Restore Complete",
                    "✅ Google Drive se data restore ho gaya!\n\n"
                    "Software band karke dobara kholen — sab data wapas aa jayega.\n\n"
                    f"💾 Purana data backup: {os.path.basename(auto_bkp)}")

            except Exception as e:
                bkp_status.config(text=f"❌ Drive restore fail: {str(e)[:60]}", fg=C_RED)
                messagebox.showerror("Drive Restore Error", str(e))

        # Show current auto-backup folder if set
        try:
            conn = get_db()
            _abf = conn.execute("SELECT value FROM settings WHERE key='auto_backup_folder'").fetchone()
            conn.close()
            if _abf and _abf[0]:
                tk.Label(sec_bkp,
                         text=f"📁 Auto-backup folder: {_abf[0]}",
                         font=("Segoe UI",8), bg=C_BG, fg="#553C9A").pack(anchor="w", pady=(0,6))
        except: pass

        # Buttons row — local
        btn_row = tk.Frame(sec_bkp, bg=C_BG)
        btn_row.pack(anchor="w", pady=(4,4))
        make_btn(btn_row, "💾 Backup Karo (Local)", do_backup,
                 bg="#8B1A1A", pady=8, padx=14).pack(side="left", padx=(0,8))
        make_btn(btn_row, "📂 Restore Karo (Local)", do_restore,
                 bg=C_AMBER, pady=8, padx=14).pack(side="left", padx=(0,8))
        make_btn(btn_row, "⚙️ Auto-Backup Folder Set Karo", auto_backup_setup,
                 bg="#553C9A", pady=8, padx=14).pack(side="left")

        # Buttons row — Google Drive
        gdrive_row = tk.Frame(sec_bkp, bg=C_BG)
        gdrive_row.pack(anchor="w", pady=(2,4))
        make_btn(gdrive_row, "☁️ Google Drive Backup", do_gdrive_backup,
                 bg="#1557A0", pady=8, padx=14).pack(side="left", padx=(0,8))
        make_btn(gdrive_row, "☁️ Google Drive Restore", do_gdrive_restore,
                 bg="#0F6B47", pady=8, padx=14).pack(side="left")

        tk.Label(sec_bkp,
                 text="💡 Local backup: USB ya koi bhi folder mein save karo.\n"
                      "   Google Drive backup: internet chahiye — credentials.json setup karna hoga (pehli baar).",
                 font=("Segoe UI",8,"italic"), bg=C_BG, fg=C_LGRAY).pack(anchor="w", pady=(8,0))

