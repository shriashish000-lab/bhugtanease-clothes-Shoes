    def _sale_add_item(self):
        prod = self._s_prod.get().strip()
        if not prod:
            messagebox.showerror("Error","Product select karo!"); return
        try:
            qty  = float(self._s_qty.get())
            rate = float(self._s_rate.get())
            gst  = float(self._s_gst.get())
            disc_val = float(getattr(self,"_s_disc",type("",(),{"get":lambda s:0})()).get() or 0)
        except:
            messagebox.showerror("Error","Qty aur Rate sahi numbers bharo!"); return
        if qty <= 0:
            messagebox.showerror("Error","Qty 0 se zyada honi chahiye!"); return
        hsn   = self._prod_dict.get(prod, {}).get("hsn", "")
        size  = getattr(self,"_s_size",None)
        color = getattr(self,"_s_color",None)
        s_val = size.get().strip()  if size  else ""
        c_val = color.get().strip() if color else ""

        # Discount: % ya ₹
        disc_type = getattr(self,"_s_disc_type",None)
        dtype = disc_type.get() if disc_type else "%"
        if dtype == "₹":
            disc_amt = disc_val                        # flat ₹ amount
            disc_pct = round(disc_val / rate * 100, 2) if rate else 0
        else:
            disc_pct = disc_val                        # percent
            disc_amt = round(rate * disc_pct / 100, 2)

        rate_after_disc = rate - disc_amt
        taxable  = round(qty * rate_after_disc, 2)
        gst_amt  = round(taxable * gst / 100, 2)
        grand    = round(taxable + gst_amt, 2)
        self._sale_items.append({
            "product":prod,"hsn":hsn,"qty":qty,"rate":rate,
            "discount":disc_pct,"disc_amt":disc_amt,"disc_type":dtype,
            "taxable":taxable,"gst":gst,"gst_amt":gst_amt,"grand":grand,
            "size":s_val,"color":c_val
        })
        self._sale_render()
        self._s_qty.set("")
        self._s_prod.set("")
        self._s_rate.set("")
        if hasattr(self,"_s_disc"): self._s_disc.set("0")
        if hasattr(self,"_s_size"): self._s_size.set("")
        if hasattr(self,"_s_color"): self._s_color.set("")

    def _sale_render(self):
        clear_table_rows(self._s_tbl)
        total = 0
        for i, it in enumerate(self._sale_items):
            total += it["grand"]
            bg = C_WHITE if i%2==0 else "#F7FAFC"
            _dv = it.get("discount",0); _dt = it.get("disc_type","%"); _da = it.get("disc_amt",0)
            disc_str = (f"₹{_da:.0f}" if _dt=="₹" else f"{_dv}%") if _dv else "-"
            desc = it["product"][:16]
            if it.get("size"): desc += f" [{it['size']}]"
            if it.get("color"): desc += f" {it['color']}"
            vals = [i+1, desc, it["hsn"], it["qty"],
                    f"₹{it['rate']:.2f}", disc_str, f"₹{it['taxable']:.2f}",
                    f"{it['gst']}%", f"₹{it['gst_amt']:.2f}",
                    f"₹{it['grand']:.0f}", "✕"]
            for j, val in enumerate(vals):
                if j == 10:
                    tk.Button(self._s_tbl, text="✕", font=("Segoe UI",9),
                              bg=bg, fg=C_RED, relief="flat", cursor="hand2", bd=0,
                              command=lambda idx=i: self._sale_del(idx)
                              ).grid(row=i+1,column=j,sticky="nsew",padx=1,pady=0)
                else:
                    tk.Label(self._s_tbl, text=str(val), font=("Segoe UI",9),
                             bg=bg, fg=C_GRAY, anchor="w", padx=6, pady=4
                             ).grid(row=i+1,column=j,sticky="nsew",padx=1,pady=0)
        self._s_total_var.set(f"₹{round(total):,}")
        self._s_words_var.set(num_to_words(total))

    def _sale_del(self, idx):
        self._sale_items.pop(idx)
        self._sale_render()

    def _sale_toggle_gst_mode(self):
        """GST Bill checkbox toggle — GST fields on/off karta hai."""
        is_gst = self._s_is_gst.get()
        if is_gst:
            # GST bill mode — GST% field aur override wapas enable karo
            if hasattr(self, "_s_gst_cb"):
                self._s_gst_cb.config(state="readonly")
            if getattr(self, "_s_gst", None) and self._s_gst.get() == "0":
                self._s_gst.set("5")
            if hasattr(self, "_gst_state_lbl"):
                self._gst_state_lbl.pack(side="left")
            if hasattr(self, "_gst_override"):
                self._gst_override.pack(side="left", padx=10)
            self._s_gst_mode_lbl.config(
                text="GST bill — CGST/SGST/IGST calculate hoga", fg="#276749")
        else:
            # Non-GST bill mode — GST% 0 kardo aur GST fields chhupao
            if hasattr(self, "_s_gst_cb"):
                self._s_gst_cb.config(state="disabled")
            if getattr(self, "_s_gst", None):
                self._s_gst.set("0")
            if hasattr(self, "_gst_override"):
                self._gst_override.pack_forget()
            if hasattr(self, "_gst_state_lbl"):
                self._gst_state_lbl.pack_forget()
            self._s_gst_mode_lbl.config(
                text="Non-GST Bill — simple bill banega, koi tax nahi lagega", fg="#92400E")

    def _sale_save(self):
        if not self._sale_items:
            messagebox.showerror("Error","Koi item nahi add kiya!"); return
        bill_no = self._s_billno.get()
        date    = self._s_date.get()
        party   = self._s_party.get().strip() or "Walk-in"
        grand   = sum(it["grand"] for it in self._sale_items)
        gst_type = getattr(self, "_gst_type_var", None)
        gst_type_val = gst_type.get() if gst_type else "CGST+SGST"
        is_gst_bill = getattr(self, "_s_is_gst", None)
        if is_gst_bill is not None and not is_gst_bill.get():
            gst_type_val = "NON-GST"
        # Walk-in fields (naam ab sirf ek hi "Customer Name" field se aata hai)
        wk_mob   = getattr(self, "_s_walkin_mob",   None)
        wk_addr  = getattr(self, "_s_walkin_addr",  None)
        wk_gstin = getattr(self, "_s_walkin_gstin", None)
        walkin_mob   = wk_mob.get().strip()   if wk_mob   else ""
        walkin_addr  = wk_addr.get().strip()  if wk_addr  else ""
        walkin_gstin = wk_gstin.get().strip() if wk_gstin else ""
        conn = get_db()
        pr = conn.execute("SELECT * FROM parties WHERE name=?", (party,)).fetchone()

        save_regular_var = getattr(self, "_s_save_regular", None)
        save_regular = save_regular_var.get() if save_regular_var else True
        if not pr and save_regular and party and party != "Walk-in":
            # Naya customer hai aur "Save as Regular Customer" checked hai — parties list mein add karo
            conn.execute(
                "INSERT INTO parties(name,ptype,mobile,gstin,address,state,email) VALUES(?,?,?,?,?,?,?)",
                (party, "Customer", walkin_mob, walkin_gstin, walkin_addr, "Uttar Pradesh", "")
            )
            conn.commit()
            pr = conn.execute("SELECT * FROM parties WHERE name=?", (party,)).fetchone()

        p_gstin = walkin_gstin or (pr["gstin"] if pr else "")
        p_addr  = walkin_addr  or (pr["address"] if pr else "")
        p_mob   = walkin_mob   or (pr["mobile"]  if pr else "")
        p_state = (pr["state"] if pr and pr["state"] else "") if pr else ""
        try:
            c = conn.cursor()
            s_pm = getattr(self, "_s_paymode", None)
            s_dd = getattr(self, "_s_due", None)
            spm = s_pm.get() if s_pm else "Cash"
            sdd = s_dd.get().strip() if s_dd else ""
            c.execute("INSERT INTO sales(bill_no,bill_date,party,party_gstin,party_address,party_mobile,grand_total,pay_mode,due_date,gst_type,party_state) VALUES(?,?,?,?,?,?,?,?,?,?,?)",
                      (bill_no,date,party,p_gstin,p_addr,p_mob,grand,spm,sdd,gst_type_val,p_state))
            sid = c.lastrowid
            for it in self._sale_items:
                c.execute("INSERT INTO sale_items(sale_id,product,hsn,size,color,qty,rate,discount,taxable,gst_percent,gst_amt,grand) VALUES(?,?,?,?,?,?,?,?,?,?,?,?)",
                          (sid,it["product"],it["hsn"],it.get("size",""),it.get("color",""),
                           it["qty"],it["rate"],it.get("discount",0),
                           it["taxable"],it["gst"],it["gst_amt"],it["grand"]))
            # ── Auto payment entry — Cash/UPI/Bank/Cheque pe turant paid mark karo ──
            if spm != "Credit":
                c.execute(
                    "INSERT INTO bill_payments(bill_type,bill_no,party,pay_date,amount,pay_mode,note) VALUES(?,?,?,?,?,?,?)",
                    ("sale", bill_no, party, date, grand, spm, "Auto-paid at billing")
                )
            conn.commit()
            messagebox.showinfo("Saved",f"Bill saved!\nBill No: {bill_no}\nTotal: ₹{round(grand):,}")
            self._sale_items = []
            self._show("sale")
        except sqlite3.IntegrityError:
            messagebox.showerror("Error","Bill number already exists! Page refresh karo.")
        finally:
            conn.close()

    def _sale_clear(self):
        self._sale_items = []
        self._sale_render()

    def _sale_preview(self):
        if not self._sale_items:
            messagebox.showerror("Error","Pehle items add karo!"); return
        party_key = self._s_party.get().strip() or "Walk-in"
        conn = get_db()
        pr = conn.execute("SELECT * FROM parties WHERE name=?", (party_key,)).fetchone()
        conn.close()
        pdata = dict(pr) if pr else {"name":party_key,"gstin":"","address":"","mobile":"","state":""}
        pdata["name"] = party_key
        # Walk-in fields override (naam ab alag se nahi, sirf mobile/address/gstin)
        wk_mob   = getattr(self, "_s_walkin_mob",   None)
        wk_addr  = getattr(self, "_s_walkin_addr",  None)
        wk_gstin = getattr(self, "_s_walkin_gstin", None)
        if wk_mob and wk_mob.get().strip():
            pdata["mobile"]  = wk_mob.get().strip()
        if wk_addr and wk_addr.get().strip():
            pdata["address"] = wk_addr.get().strip()
        if wk_gstin and wk_gstin.get().strip():
            pdata["gstin"]   = wk_gstin.get().strip()
        gst_type = getattr(self, "_gst_type_var", None)
        gst_type_val = gst_type.get() if gst_type else "CGST+SGST"
        is_gst_bill = getattr(self, "_s_is_gst", None)
        if is_gst_bill is not None and not is_gst_bill.get():
            gst_type_val = "NON-GST"
        InvoiceWin(self.root, {
            "bill_no":self._s_billno.get(), "date":self._s_date.get(),
            "party":pdata, "items":self._sale_items,
            "grand":sum(it["grand"] for it in self._sale_items),
            "gst_type": gst_type_val
        })

