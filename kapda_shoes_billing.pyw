        def do_backup():
            """Database ka backup kisi bhi folder / USB mein save karo."""
            import shutil, datetime as _dt
            from tkinter import filedialog
            timestamp = _dt.datetime.now().strftime("%Y%m%d_%H%M%S")
            default_name = f"BhugtanEase_Backup_{timestamp}.db"
            dest = filedialog.asksaveasfilename(
                title="Backup kahan save karein?",
                initialfile=default_name,
                defaultextension=".db",
                filetypes=[("Database Backup", "*.db"), ("All Files", "*.*")]
            )
            if not dest:
                return
            try:
                # Safe backup — SQLite WAL flush karke copy
                import sqlite3 as _sq
                src_conn = _sq.connect(DB_FILE)
                dest_conn = _sq.connect(dest)
                src_conn.backup(dest_conn)
                src_conn.close(); dest_conn.close()
                size_kb = os.path.getsize(dest) // 1024
                bkp_status.config(
                    text=f"✅ Backup save hua! ({size_kb} KB)  📁 {dest}",
                    fg="#276749")
                pg.after(8000, lambda: bkp_status.config(text=""))
                messagebox.showinfo("Backup Complete",
                    f"✅ Backup save ho gaya!\n\n📁 {dest}\n\n"
                    "💡 Isko USB / Google Drive mein copy karke rakhein\n"
                    "   taaki laptop kharab hone par bhi data safe rahe.")
            except Exception as e:
                messagebox.showerror("Backup Error", f"Backup fail ho gaya:\n{str(e)}")

        def do_restore():
            """Backup file se data restore karo."""
            import shutil, datetime as _dt
            from tkinter import filedialog
            if not messagebox.askyesno("Restore Confirm",
                    "⚠️ RESTORE se ABHI KA POORA DATA HAT JAYEGA!\n\n"
                    "Sirf tabhi karo jab aapke paas sahi backup file ho.\n\n"
                    "Kya aap continue karna chahte hain?"):
                return
            src = filedialog.askopenfilename(
                title="Backup file select karo",
                filetypes=[("Database Backup", "*.db"), ("All Files", "*.*")]
            )
            if not src:
                return
            # Verify it's a valid SQLite file
            try:
                import sqlite3 as _sq
                test = _sq.connect(src)
                tables = test.execute("SELECT name FROM sqlite_master WHERE type='table'").fetchall()
                test.close()
                table_names = [t[0] for t in tables]
                if "products" not in table_names and "parties" not in table_names:
                    messagebox.showerror("Invalid File",
                        "Yeh valid BhugtanEase backup file nahi lagti!\n"
                        "Sahi .db backup file select karo.")
                    return
            except Exception as e:
                messagebox.showerror("Invalid File", f"File padhne mein error:\n{str(e)}"); return

            # Auto-backup current data before restore
            import datetime as _dt2
            ts = _dt2.datetime.now().strftime("%Y%m%d_%H%M%S")
            auto_bkp = DB_FILE.replace(".db", f"_before_restore_{ts}.db")
            try:
                import sqlite3 as _sq2
                sc = _sq2.connect(DB_FILE); dc = _sq2.connect(auto_bkp)
                sc.backup(dc); sc.close(); dc.close()
            except: pass

            try:
                import sqlite3 as _sq3
                sc = _sq3.connect(src); dc = _sq3.connect(DB_FILE)
                sc.backup(dc); sc.close(); dc.close()
                messagebox.showinfo("Restore Complete",
                    "✅ Data restore ho gaya!\n\n"
                    "Software band karke dobara kholen — sab data wapas aa jayega.\n\n"
                    f"💾 Purana data backup: {os.path.basename(auto_bkp)}")
