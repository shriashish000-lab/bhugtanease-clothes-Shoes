        def load_hist():
            clear_table_rows(htbl)
            d = get_db()
            q = "SELECT * FROM damage_stock WHERE 1=1"
            params = []
            hp = v_hprod.get().strip()
            hs = v_hstatus.get()
            hf3 = v_hfrom.get().strip()
            ht  = v_hto.get().strip()
            if hp: q += " AND product=?"; params.append(hp)
            if hs != "All": q += " AND status=?"; params.append(hs)
            if hf3: q += " AND damage_date>=?"; params.append(hf3)
            if ht:  q += " AND damage_date<=?"; params.append(ht)
            q += " ORDER BY damage_date DESC, id DESC"
            rows = d.execute(q, params).fetchall()
            d.close()
            status_colors = {
                "Pending":                "#E53E3E",
                "Under Repair":           "#975A16",
                "Salvaged / Repaired":    "#276749",
                "Disposed":               "#5C3D2E",
                "Returned to Supplier":   "#8B1A1A",
            }
            for i, r in enumerate(rows):
                bg = C_WHITE if i%2==0 else "#FFF5F5"
                sc = status_colors.get(r["status"], C_GRAY)
                vals = [r["damage_no"], r["damage_date"], r["product"][:16], int(r["qty"]),
                        r["damage_type"][:18], r["source"][:14],
                        f"\u20b9{r['repair_cost']:.0f}" if r["repair_cost"] else "-",
                        r["status"], ""]
                for j, val in enumerate(vals):
                    if j == 8:
                        rx = dict(r)
                        tk.Button(htbl, text="\u270f", font=("Segoe UI", 9),
                                  bg=bg, fg="#8B1A1A", relief="flat", cursor="hand2", bd=0,
                                  command=lambda rx=rx: open_update(rx)
                                  ).grid(row=i+1, column=j, sticky="nsew", padx=1)
                    elif j == 7:
                        tk.Label(htbl, text=str(val), font=("Segoe UI", 9, "bold"),
                                 bg=bg, fg=sc, anchor="w", padx=6, pady=4
                                 ).grid(row=i+1, column=j, sticky="nsew", padx=1)
                    else:
                        tk.Label(htbl, text=str(val), font=("Segoe UI", 9),
                                 bg=bg, fg=C_GRAY, anchor="w", padx=6, pady=4
                                 ).grid(row=i+1, column=j, sticky="nsew", padx=1)

        def open_update(rx):
            """Status update popup."""
            win = tk.Toplevel(); win.title(f"Update — {rx['damage_no']}")
            win.configure(bg=C_WHITE); win.geometry("480x380"); win.grab_set()
            tk.Frame(win, bg=C_RED, height=5).pack(fill="x")
            tk.Label(win, text=f"\U0001f6a8  {rx['damage_no']}  —  Update Status",
                     font=("Segoe UI",13,"bold"), bg=C_WHITE, fg=C_RED).pack(pady=(12,4))
            tf = tk.Frame(win, bg="#F7FAFC", padx=20, pady=10)
            tf.pack(fill="x", padx=20)
            for label, val in [("Product", rx["product"]),
                                ("Qty", f"{int(rx['qty'])} pcs"),
                                ("Damage Type", rx["damage_type"]),
                                ("Current Status", rx["status"]),
                                ("Description", rx["description"] or "-")]:
                lrow = tk.Frame(tf, bg="#F7FAFC"); lrow.pack(fill="x", pady=1)
                tk.Label(lrow, text=f"{label}:", font=("Segoe UI",9,"bold"),
                         width=14, anchor="w", bg="#F7FAFC", fg=C_GRAY).pack(side="left")
                tk.Label(lrow, text=str(val), font=("Segoe UI",9),
                         bg="#F7FAFC", fg="#2A0A0A").pack(side="left")
            tk.Frame(win, bg=C_BORDER, height=1).pack(fill="x", padx=20, pady=8)

            uf = tk.Frame(win, bg=C_WHITE, padx=20); uf.pack(fill="x")
            tk.Label(uf, text="Naya Status:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
            v_ns = tk.StringVar(value=rx["status"])
            ttk.Combobox(uf, textvariable=v_ns, width=22, state="readonly",
                         values=["Pending","Under Repair","Salvaged / Repaired",
                                 "Disposed","Returned to Supplier"]).pack(side="left", padx=6)

            uf2 = tk.Frame(win, bg=C_WHITE, padx=20); uf2.pack(fill="x", pady=6)
            tk.Label(uf2, text="Resolution Note:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
            v_res = tk.StringVar(value=rx["resolution"] or "")
            ttk.Entry(uf2, textvariable=v_res, width=34).pack(side="left", padx=6)

            uf3 = tk.Frame(win, bg=C_WHITE, padx=20); uf3.pack(fill="x", pady=4)
            tk.Label(uf3, text="Repair Cost (\u20b9):", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
            v_rc2 = tk.StringVar(value=str(rx["repair_cost"]))
            ttk.Entry(uf3, textvariable=v_rc2, width=12).pack(side="left", padx=6)

            # Stock wapas add option (for Salvaged/Returned)
            v_add_stk = tk.BooleanVar(value=False)
            stk_cb = tk.Checkbutton(uf3, text="Stock wapas add karein",
                                     variable=v_add_stk, font=("Segoe UI",9),
                                     bg=C_WHITE, fg=C_GRAY, activebackground=C_WHITE)
            stk_cb.pack(side="left", padx=(14,0))

            def on_status_change(*a):
                ns = v_ns.get()
                if ns in ("Salvaged / Repaired", "Returned to Supplier"):
                    v_add_stk.set(True)
                else:
                    v_add_stk.set(False)
            v_ns.trace_add("write", on_status_change)

            def do_update():
                try: rc2 = float(v_rc2.get())
                except: rc2 = rx["repair_cost"]
                d = get_db()
                d.execute(
                    "UPDATE damage_stock SET status=?, resolution=?, repair_cost=?, resolved_date=? "
                    "WHERE damage_no=?",
                    (v_ns.get(), v_res.get().strip(), rc2,
                     str(_dt.date.today()) if v_ns.get() not in ("Pending","Under Repair") else "",
                     rx["damage_no"]))
                if v_add_stk.get():
                    d.execute(
                        "INSERT INTO stock_movements(move_date,product,move_type,qty,ref_no,reason) "
                        "VALUES(?,?,?,?,?,?)",
                        (str(_dt.date.today()), rx["product"], "IN", rx["qty"],
                         rx["damage_no"], f"Damage Resolved: {v_ns.get()}"))
                d.commit(); d.close()
                messagebox.showinfo("Updated!", f"{rx['damage_no']} status update ho gaya!\n{v_ns.get()}")
                win.destroy()
                load_hist(); load_summary(); load_pending()

            bf3 = tk.Frame(win, bg=C_WHITE, padx=20); bf3.pack(fill="x", pady=8)
            make_btn(bf3, "\u2705  Update Karo", do_update, bg="#276749").pack(side="left")
