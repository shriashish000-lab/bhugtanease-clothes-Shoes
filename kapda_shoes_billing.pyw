def _make_logo_label(parent, bg_color, height=48):
    """Logo widget banao — PIL available ho to image (best quality),
    warna seedha Tk ke built-in PNG support se image, warna text fallback."""
    try:
        import base64 as _b64
        from io import BytesIO
        from PIL import Image, ImageTk
        _img_data = _b64.b64decode(LOGO_B64)
        _pil = Image.open(BytesIO(_img_data)).convert("RGBA")
        # White background composite
        _bg = Image.new("RGBA", _pil.size, (255, 255, 255, 0))
        _bg.paste(_pil, mask=_pil.split()[3])
        _nw = int(_pil.size[0] * height / _pil.size[1])
        _bg = _bg.resize((_nw, height), Image.LANCZOS)
        _photo = ImageTk.PhotoImage(_bg)
        lbl = tk.Label(parent, image=_photo, bg=bg_color)
        lbl._logo_ref = _photo   # garbage collection se bachao
        return lbl
    except Exception:
        pass
    try:
        # PIL nahi hai — Tk ka apna built-in PNG support use karo (Pillow ki zaroorat nahi)
        import base64 as _b64
        import tempfile as _tempfile
        _img_data = _b64.b64decode(LOGO_B64)
        _tmp = _tempfile.NamedTemporaryFile(suffix=".png", delete=False)
        _tmp.write(_img_data); _tmp.close()
        _photo = tk.PhotoImage(file=_tmp.name)
        _w, _h = _photo.width(), _photo.height()
        if _h > height:
            _s = max(1, _h // height)
            _photo = _photo.subsample(_s, _s)
        lbl = tk.Label(parent, image=_photo, bg=bg_color)
        lbl._logo_ref = _photo   # garbage collection se bachao
        return lbl
    except Exception:
        return tk.Label(parent, text="BhugtanEase",
                        font=("Segoe UI", 20, "bold"), bg=bg_color, fg="#D4A017")

