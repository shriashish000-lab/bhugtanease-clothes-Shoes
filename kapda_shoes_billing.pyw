        form.pack(fill="x", pady=(0, 8))
        tk.Label(form, text="Exchange Entry  (Multiple products wapas + multiple naye products)",
                 font=("Segoe UI", 10, "bold"), bg=C_WHITE, fg="#5C1A1A").pack(anchor="w", padx=16, pady=(10, 6))

        row1 = tk.Frame(form, bg=C_WHITE); row1.pack(fill="x", padx=16, pady=4)
