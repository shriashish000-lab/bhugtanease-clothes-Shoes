            def generate_pdf():
                selected = [nm for nm, var in _prod_vars.items() if var.get()]
                if not selected:
                    messagebox.showerror("Error","Koi product select nahi kiya!"); return
                try:
                    from reportlab.lib.pagesizes import A4
                    from reportlab.lib.units import mm
                    from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer, Image as RLImage
                    from reportlab.lib.styles import ParagraphStyle
                    from reportlab.lib.enums import TA_CENTER
                    from reportlab.lib import colors as rl_colors
                    import barcode as _bc2
                    from barcode.writer import ImageWriter as _IW2
                    import io, os, sys, tempfile
                    from tkinter import filedialog

                    save_path = filedialog.asksaveasfilename(
                        defaultextension=".pdf",
                        filetypes=[("PDF","*.pdf")],
                        initialfile="barcodes.pdf",
                        title="Barcode PDF save karo")
                    if not save_path: return

                    _sp = get_shop()
                    lsize_map = {
                        "50x25mm": (50*mm, 25*mm),
                        "60x30mm": (60*mm, 30*mm),
                        "70x35mm": (70*mm, 35*mm),
                        "100x50mm":(100*mm,50*mm),
                        "A4 Sheet":(A4[0], A4[1]),
                    }
                    lw, lh = lsize_map.get(v_lsize.get(), (50*mm, 25*mm))
                    copies = max(1, int(v_copies.get() or 1))
                    bc_type = v_bctype.get()

                    # Decide columns per row based on label width
                    if lw >= 190*mm: cols = 1
                    elif lw >= 80*mm: cols = 3
                    else: cols = 4

                    doc = SimpleDocTemplate(save_path, pagesize=A4,
                        leftMargin=8*mm, rightMargin=8*mm,
                        topMargin=8*mm, bottomMargin=8*mm)

                    def ps(nm, sz=7, bold=False, align=TA_CENTER):
                        return ParagraphStyle(nm, fontSize=sz,
                            fontName="Helvetica-Bold" if bold else "Helvetica",
                            alignment=align, leading=sz+2)

                    d3 = get_db()
                    story = []
                    cells = []

                    for nm in selected:
                        row2 = d3.execute("SELECT * FROM products WHERE name=?", (nm,)).fetchone()
                        if not row2: continue
                        bc_val = row2["barcode"] or ""
                        if not bc_val:
                            # Auto generate if empty
                            import time, hashlib
                            raw = f"{nm}{row2['id']}{int(time.time())}"
                            bc_val = hashlib.md5(raw.encode()).hexdigest()[:12].upper()
                            d3.execute("UPDATE products SET barcode=? WHERE name=?", (bc_val, nm))
                            d3.commit()

                        # Generate barcode image
                        try:
                            BCClass = _bc2.get_barcode_class(bc_type)
                            buf = io.BytesIO()
                            writer = _IW2()
                            bc_obj = BCClass(bc_val, writer=writer)
                            bc_obj.write(buf, options={
                                "module_height": 8.0,
                                "module_width": 0.8,
                                "quiet_zone": 2.0,
                                "font_size": 6,
                                "text_distance": 2.0,
                                "background": "white",
                                "foreground": "black",
                            })
                            buf.seek(0)
                            bc_img = RLImage(buf, width=lw*0.82, height=lh*0.46)
                        except Exception as e:
                            bc_img = Paragraph(f"BC ERR: {e}", ps("e",6))

                        # Build label cell content
                        label_items = []
                        if v_show_shop.get() and _sp["name"]:
                            label_items.append(Paragraph(_sp["name"][:22], ps("sh",6,True)))
                        label_items.append(bc_img)
                        if v_show_name.get():
                            label_items.append(Paragraph(nm[:26], ps("nm",6,True)))
                        if v_show_price.get():
                            label_items.append(Paragraph(f"₹{row2['sale_rate']:.0f}", ps("pr",7,True)))

                        # Wrap in a mini Table for border
                        cell_tbl = Table([[item] for item in label_items],
                            colWidths=[lw*0.95])
                        cell_tbl.setStyle(TableStyle([
                            ("BOX",(0,0),(-1,-1),0.5,rl_colors.black),
                            ("TOPPADDING",(0,0),(-1,-1),1),
                            ("BOTTOMPADDING",(0,0),(-1,-1),1),
                            ("LEFTPADDING",(0,0),(-1,-1),2),
                            ("RIGHTPADDING",(0,0),(-1,-1),2),
                        ]))

                        for _ in range(copies):
                            cells.append(cell_tbl)

                    d3.close()

                    # Arrange cells in a grid
                    rows_list = []
                    for i in range(0, len(cells), cols):
                        row_cells = cells[i:i+cols]
                        while len(row_cells) < cols:
                            row_cells.append("")
                        rows_list.append(row_cells)

                    if rows_list:
                        col_widths = [lw] * cols
                        grid = Table(rows_list, colWidths=col_widths,
                                     rowHeights=[lh]*len(rows_list))
                        grid.setStyle(TableStyle([
                            ("VALIGN",(0,0),(-1,-1),"MIDDLE"),
                            ("ALIGN",(0,0),(-1,-1),"CENTER"),
                            ("TOPPADDING",(0,0),(-1,-1),2),
                            ("BOTTOMPADDING",(0,0),(-1,-1),2),
                        ]))
                        story.append(grid)

                    doc.build(story)
                    if sys.platform=="win32": os.startfile(save_path)
                    elif sys.platform=="darwin": __import__("subprocess").Popen(["open",save_path])
                    else: __import__("subprocess").Popen(["xdg-open",save_path])
                    messagebox.showinfo("PDF Ready!",
                        f"Barcode PDF ban gayi!\n{len(selected)} products × {copies} copies\n\n{save_path}")
                    render_list()

                except ImportError as ie:
                    messagebox.showerror("Library Missing",
                        f"Library install nahi hai: {ie}\n\nCMD mein chalao:\npip install python-barcode[images] reportlab Pillow")
                except Exception as ex:
                    messagebox.showerror("Error", f"PDF nahi ban saki:\n{str(ex)}")

            make_btn(right, "📄 Generate Barcode PDF", generate_pdf,
                     bg=C_RED, pady=8).pack(padx=12, pady=(0,4), fill="x")

            # Single barcode preview
            tk.Frame(right, bg=C_BORDER, height=1).pack(fill="x", padx=12, pady=4)
            tk.Label(right, text="🖼️ Single Barcode Preview:",
                     font=("Segoe UI",9,"bold"), bg=C_WHITE, fg="#5C1A1A").pack(anchor="w", padx=12, pady=(4,2))
            prev_lbl = tk.Label(right, bg=C_WHITE, text="Product select karke\nPreview dabao",
                                font=("Segoe UI",8,"italic"), fg=C_LGRAY)
            prev_lbl.pack(padx=12, pady=4)

            def show_preview():
                selected2 = [nm for nm, var in _prod_vars.items() if var.get()]
                if not selected2:
                    messagebox.showinfo("Select","Pehle koi ek product select karo!"); return
                nm = selected2[0]
                d4 = get_db()
                row3 = d4.execute("SELECT barcode FROM products WHERE name=?", (nm,)).fetchone()
                d4.close()
                bc_val = row3["barcode"] if row3 else ""
                if not bc_val:
                    messagebox.showinfo("No Barcode",
                        f"'{nm}' ka barcode nahi hai.\n'Auto Assign' karo pehle!"); return
                try:
                    import barcode as _bc3
                    from barcode.writer import ImageWriter as _IW3
                    import io
                    from PIL import Image as PilImg, ImageTk
                    BCClass = _bc3.get_barcode_class(v_bctype.get())
                    buf = io.BytesIO()
                    BCClass(bc_val, writer=_IW3()).write(buf, options={
                        "module_height":10,"module_width":1.2,"quiet_zone":3,"font_size":8
                    })
                    buf.seek(0)
                    img = PilImg.open(buf)
                    img.thumbnail((240, 120))
                    tk_img = ImageTk.PhotoImage(img)
                    prev_lbl.config(image=tk_img, text="", bg=C_WHITE)
                    prev_lbl.image = tk_img
                except Exception as e:
                    prev_lbl.config(text=f"Preview error:\n{e}", image="")

            make_btn(right, "👁 Preview", show_preview, bg="#8B1A1A", pady=5
                     ).pack(padx=12, pady=(0,8), fill="x")

        make_btn(bf, "🏷️ Barcode Generator", open_barcode_generator,
                 bg="#553C9A", pady=6).pack(side="left", padx=8)
        refresh()

