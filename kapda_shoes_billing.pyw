        def do_save_damage():
            prod = v_prod.get().strip()
            if not prod:
                messagebox.showerror("Error", "Product select karo!"); return
            try:
                qty = float(v_qty.get()); assert qty > 0
            except:
                messagebox.showerror("Error", "Damage Qty sahi bharo!"); return
            if not v_dtype.get():
                messagebox.showerror("Error", "Damage Type select karo!"); return
            if v_deduct.get():
                cur = get_stock(prod)
                if qty > cur:
                    if not messagebox.askyesno("Warning",
                        f"Current stock {int(cur)} hai aur {int(qty)} damage kar rahe ho.\nFir bhi save karo?"):
                        return
            try: rcost = float(v_rcost.get())
            except: rcost = 0.0

            d = get_db()
            n = d.execute("SELECT COUNT(*) FROM damage_stock").fetchone()[0]
            dno = "DMG-{:03d}".format(n+1)
            d.execute(
                "INSERT INTO damage_stock(damage_no,damage_date,product,qty,damage_type,source,"
                "ref_bill,description,repair_cost,status) VALUES(?,?,?,?,?,?,?,?,?,?)",
                (dno, v_date.get(), prod, qty, v_dtype.get(), v_source.get(),
                 v_ref.get().strip(), v_desc.get().strip(), rcost, v_status.get()))
            if v_deduct.get():
                d.execute(
                    "INSERT INTO stock_movements(move_date,product,move_type,qty,ref_no,reason) "
                    "VALUES(?,?,?,?,?,?)",
                    (v_date.get(), prod, "OUT", qty, dno, f"Damage: {v_dtype.get()}"))
            d.commit(); d.close()
            messagebox.showinfo("Saved!", f"Damage record {dno} save ho gaya!\n"
                                f"Product: {prod}  Qty: {int(qty)}\n"
                                f"{'Stock se hata diya.' if v_deduct.get() else 'Stock mein rakha (deduct nahi kiya).'}")
            v_prod.set(""); v_qty.set(""); v_ref.set(""); v_desc.set("")
            v_rcost.set("0"); v_dtype.set(""); v_source.set("")
            v_stk_lbl.set("Stock: -")
            load_summary()

