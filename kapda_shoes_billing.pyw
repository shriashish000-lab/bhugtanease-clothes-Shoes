                 bg=C_WHITE,fg=C_ACCENT).pack(side="left",padx=12,pady=8)

        def load():
            clear_table_rows(tbl)
            frm=sh_from.get(); to=sh_to.get(); q_txt=sh_search.get().lower()
            d = get_db()
            rows = d.execute("SELECT * FROM exchanges ORDER BY exchange_date DESC").fetchall()
            d.close()
            ri = 0
            for r in rows:
                if frm and r["exchange_date"] < frm: continue
                if to and r["exchange_date"] > to: continue
                if q_txt and q_txt not in r["exchange_no"].lower() and \
                   q_txt not in r["party"].lower() and q_txt not in r["orig_bill"].lower():
                    continue
                bg = C_WHITE if ri%2==0 else "#EBF8FF"
                diff_val = r["diff_amount"]
                diff_str = (f"+₹{diff_val:,.0f}" if diff_val>0
                            else (f"-₹{abs(diff_val):,.0f}" if diff_val<0 else "₹0"))
                d2 = get_db()
                ri_count = d2.execute("SELECT COUNT(*) FROM exchange_return_items WHERE exchange_no=?",
                                      (r["exchange_no"],)).fetchone()[0]
                ni_count = d2.execute("SELECT COUNT(*) FROM exchange_new_items WHERE exchange_no=?",
                                      (r["exchange_no"],)).fetchone()[0]
                d2.close()
                exno = r["exchange_no"]
                vals = [exno, fmt_date(r["exchange_date"]), r["orig_bill"], r["party"][:16],
