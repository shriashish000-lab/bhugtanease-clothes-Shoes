        bills       = [r[0] for r in db2.execute("SELECT bill_no FROM sales ORDER BY bill_date DESC").fetchall()]
        all_prods   = [r[0] for r in db2.execute("SELECT name FROM products ORDER BY name").fetchall()]
        db2.close()
        cb_bill = ttk.Combobox(row1, textvariable=v_bill, values=bills, width=16)
        cb_bill.pack(side="left", padx=(2, 14))
        tk.Label(row1, text="Customer:", font=("Segoe UI", 9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_party = tk.StringVar()
        e_party = ttk.Entry(row1, textvariable=v_party, width=20, state="readonly")
        e_party.pack(side="left", padx=(2, 0))

        row2 = tk.Frame(form, bg=C_WHITE); row2.pack(fill="x", padx=16, pady=(0, 8))
        tk.Label(row2, text="Exchange Reason:", font=("Segoe UI", 9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_reason = tk.StringVar()
        ttk.Combobox(row2, textvariable=v_reason, width=38,
                     values=["Size Galat Tha", "Color Pasand Nahi", "Defective / Kharab Maal",
                             "Customer Ko Dusra Chahiye", "Wrong Item Diya", "Other"]).pack(side="left", padx=(4, 0))

        # ── Two-column add-item area ──
        two_col = tk.Frame(p, bg=C_BG); two_col.pack(fill="x", pady=(0, 4))
        two_col.columnconfigure(0, weight=1, uniform="exc")
        two_col.columnconfigure(1, weight=1, uniform="exc")

        # LEFT: Wapas aane wale (Return side)
        lf = tk.Frame(two_col, bg="#FFF5F5", highlightthickness=1, highlightbackground="#FC8181")
        lf.grid(row=0, column=0, sticky="nsew", padx=(0, 4))
        tk.Label(lf, text="\u21a9\ufe0f  Wapas Aane Wale Products  (Customer de raha hai)",
                 font=("Segoe UI", 9, "bold"), bg="#FFF5F5", fg="#9B2C2C"
                 ).pack(anchor="w", padx=10, pady=(8, 4))

        lr = tk.Frame(lf, bg="#FFF5F5"); lr.pack(fill="x", padx=8, pady=(0, 6))
