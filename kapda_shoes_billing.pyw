                above   = r["grand_total"] >= 50000
                status_txt = "✅ EWB Done" if has_ewb else ("⚠️ Mandatory!" if above else "Optional")
                status_clr = C_GREEN if has_ewb else (C_RED if above else C_GRAY)

                vals = [r["bill_no"], fmt_date(r["bill_date"]), r["party"][:16],
                        f"₹{r['grand_total']:,.0f}", ewb_no[:14] if ewb_no else "-",
                        veh, mode, str(dist), status_txt]
                fgs  = [C_ACCENT, None, None, C_GREEN if above else None,
                        C_GREEN if has_ewb else C_GRAY,
                        None, None, None, status_clr]

                for j,(val,fg) in enumerate(zip(vals,fgs)):
                    tk.Label(tbl, text=str(val), font=("Segoe UI",9),
                             bg=bg, fg=fg or C_GRAY, anchor="w", padx=4, pady=4
                             ).grid(row=i+1, column=j, sticky="nsew", padx=1)

                tk.Button(tbl, text="EWB", font=("Segoe UI",8,"bold"),
                          bg="#276749", fg="white", relief="flat", cursor="hand2",
                          command=lambda rd=r: ewb_popup(rd)
                          ).grid(row=i+1, column=9, sticky="nsew", padx=2, pady=2)

        def ewb_popup(r):
            dlg = tk.Toplevel(p.winfo_toplevel())
            dlg.title(f"E-Way Bill — {r['bill_no']}")
            dlg.geometry("520x260"); dlg.configure(bg=C_WHITE); dlg.grab_set()
            tk.Label(dlg, text=f"🚛 E-Way Bill — {r['bill_no']}",
                     font=("Segoe UI",10,"bold"), bg="#276749", fg="white", pady=8).pack(fill="x")
            frm2 = tk.Frame(dlg, bg=C_WHITE, padx=16, pady=10); frm2.pack(fill="x")

            r1 = tk.Frame(frm2, bg=C_WHITE); r1.pack(fill="x", pady=4)
            tk.Label(r1, text="EWB No:", font=("Segoe UI",9), bg=C_WHITE).pack(side="left")
            v_ewb = tk.StringVar(value=r.get("ewb_no","") or "")
            ttk.Entry(r1, textvariable=v_ewb, width=20).pack(side="left", padx=(4,14))
            tk.Label(r1, text="EWB Date:", font=("Segoe UI",9), bg=C_WHITE).pack(side="left")
            v_ed = tk.StringVar(value=r.get("ewb_date","") or "")
            make_date_entry(r1, v_ed, width=13).pack(side="left", padx=4)

            r2 = tk.Frame(frm2, bg=C_WHITE); r2.pack(fill="x", pady=4)
            tk.Label(r2, text="Vehicle No:", font=("Segoe UI",9), bg=C_WHITE).pack(side="left")
            v_veh = tk.StringVar(value=r.get("vehicle_no","") or "")
            ttk.Entry(r2, textvariable=v_veh, width=14).pack(side="left", padx=(4,14))
            tk.Label(r2, text="Mode:", font=("Segoe UI",9), bg=C_WHITE).pack(side="left")
            v_mode = tk.StringVar(value=r.get("transport_mode","Road") or "Road")
            ttk.Combobox(r2, textvariable=v_mode, width=8, state="readonly",
                         values=["Road","Rail","Air","Ship"]).pack(side="left", padx=(4,14))
            tk.Label(r2, text="Distance (km):", font=("Segoe UI",9), bg=C_WHITE).pack(side="left")
            v_dist = tk.StringVar(value=str(r.get("distance","") or ""))
            ttk.Entry(r2, textvariable=v_dist, width=8).pack(side="left", padx=4)

            r3 = tk.Frame(frm2, bg=C_WHITE); r3.pack(fill="x", pady=4)
            tk.Label(r3, text="Transporter:", font=("Segoe UI",9), bg=C_WHITE).pack(side="left")
            v_trans = tk.StringVar(value=r.get("transporter","") or "")
            ttk.Entry(r3, textvariable=v_trans, width=30).pack(side="left", padx=4)

            def save_ewb():
                try: dist_int = int(v_dist.get()) if v_dist.get().strip() else 0
                except: dist_int = 0
                conn2 = get_db()
                conn2.execute(
                    "UPDATE sales SET ewb_no=?,ewb_date=?,vehicle_no=?,transport_mode=?,distance=?,transporter=? WHERE id=?",
                    (v_ewb.get().strip(), v_ed.get().strip(),
                     v_veh.get().strip().upper(), v_mode.get(),
                     dist_int, v_trans.get().strip(), r["id"]))
                conn2.commit(); conn2.close()
                messagebox.showinfo("✅ Saved","E-Way Bill details saved!", parent=dlg)
                dlg.destroy(); load()

            bf2 = tk.Frame(dlg, bg=C_WHITE); bf2.pack(pady=(0,10))
            make_btn(bf2,"✅ Save EWB",  save_ewb,   bg=C_GREEN).pack(side="left", padx=6)
            make_btn(bf2,"Cancel",       dlg.destroy, bg=C_GRAY).pack(side="left", padx=6)

        def export_ewb():
            if not all_rows:
                messagebox.showinfo("No Data","Pehle Refresh karo!"); return
            data = [[r["bill_no"], fmt_date(r["bill_date"]), r["party"],
                     f"₹{r['grand_total']:,.0f}",
                     r.get("ewb_no","") or "", r.get("ewb_date","") or "",
                     r.get("vehicle_no","") or "", r.get("transport_mode","") or "",
                     str(r.get("distance","") or ""),
                     "Generated" if r.get("ewb_no","") else "Pending"]
                    for r in all_rows]
            try:
                export_to_excel(
                    ["Bill No","Date","Party","Grand","EWB No","EWB Date",
                     "Vehicle No","Mode","Distance","Status"],
                    data, "EWayBill_Register")
            except Exception as e:
                messagebox.showerror("Export Error", str(e))

        load()

    # ══════════════════════════════════════════════════════════════════════════
    #  SALE RETURN
    # ══════════════════════════════════════════════════════════════════════════
    def _pg_salereturn(self):
        """Sale Return — Ek se zyada products, Return Bill generate."""
        import datetime as _dt
        db = get_db()
        db.execute("""CREATE TABLE IF NOT EXISTS returns (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            return_no TEXT UNIQUE NOT NULL,
            return_type TEXT NOT NULL,
            return_date TEXT NOT NULL,
            orig_bill TEXT NOT NULL,
            party TEXT NOT NULL,
            product TEXT NOT NULL,
            qty REAL DEFAULT 0,
            rate REAL DEFAULT 0,
            gst_percent REAL DEFAULT 0,
            gst_amt REAL DEFAULT 0,
            total_amt REAL DEFAULT 0,
            reason TEXT DEFAULT '',
            created_at TEXT DEFAULT CURRENT_TIMESTAMP)""")
        # Multi-item returns table
        db.execute("""CREATE TABLE IF NOT EXISTS return_items (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            return_no TEXT NOT NULL,
            product TEXT NOT NULL,
            qty REAL DEFAULT 0,
            rate REAL DEFAULT 0,
            gst_percent REAL DEFAULT 0,
            gst_amt REAL DEFAULT 0,
            total_amt REAL DEFAULT 0)""")
        db.commit(); db.close()

        # ── Return items cart ──
        _return_items = []

        p = tk.Frame(self.content, bg=C_BG, padx=14, pady=6)
        p.pack(fill="x")
        section_title(p, "↩️ Sale Return — Customer se Maal Wapas")

        # ── Header: Date, Bill, Party ──────────────────────────────────────
        form = tk.Frame(p, bg=C_WHITE, highlightthickness=1, highlightbackground=C_BORDER)
        form.pack(fill="x", pady=(0,8))
        tk.Label(form, text="Customer Return Entry  (Ek bill ke multiple products return kar sakte ho)",
                 font=("Segoe UI",10,"bold"), bg=C_WHITE, fg="#5C1A1A").pack(anchor="w", padx=16, pady=(10,6))

        row1 = tk.Frame(form, bg=C_WHITE); row1.pack(fill="x", padx=16, pady=4)

        tk.Label(row1, text="Return Date:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_date = tk.StringVar(value=str(_dt.date.today()))
        make_date_entry(row1, v_date, width=13).pack(side="left", padx=(2,14))

        tk.Label(row1, text="Sale Bill No:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_bill = tk.StringVar()
        db2 = get_db()
        bills = [r[0] for r in db2.execute("SELECT bill_no FROM sales ORDER BY bill_date DESC").fetchall()]
        db2.close()
        cb_bill = ttk.Combobox(row1, textvariable=v_bill, values=bills, width=16)
        cb_bill.pack(side="left", padx=(2,14))

        tk.Label(row1, text="Customer:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_party = tk.StringVar()
        e_party = ttk.Entry(row1, textvariable=v_party, width=20, state="readonly")
        e_party.pack(side="left", padx=(2,0))

        # Reason (common for whole return)
        row_r = tk.Frame(form, bg=C_WHITE); row_r.pack(fill="x", padx=16, pady=4)
        tk.Label(row_r, text="Return Reason:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_reason = tk.StringVar()
        ttk.Combobox(row_r, textvariable=v_reason, width=38,
                     values=["Defective / Kharab Maal","Size Galat","Customer Ko Pasand Nahi",
                             "Damage in Transit","Excess Quantity","Wrong Item","Other"]).pack(side="left", padx=(4,0))

        # ── Add Item Area ──────────────────────────────────────────────────
        af = tk.Frame(p, bg="#FFF5F5", highlightthickness=1, highlightbackground="#FC8181")
        af.pack(fill="x", pady=(0,6))
        tk.Label(af, text="➕  Item Add Karo  (Bill select karne ke baad products auto-fill honge)",
                 font=("Segoe UI",9,"bold"), bg="#FFF5F5", fg="#9B2C2C").pack(anchor="w", padx=12, pady=(8,4))

        af_row = tk.Frame(af, bg="#FFF5F5"); af_row.pack(fill="x", padx=12, pady=(0,8))
        lbl_cfg = dict(font=("Segoe UI",8,"bold"), bg="#FFF5F5", fg="#9B2C2C")

        tk.Label(af_row, text="Product:", **lbl_cfg).pack(side="left")
        v_prod = tk.StringVar()
        cb_prod = ttk.Combobox(af_row, textvariable=v_prod, width=22)
        cb_prod.pack(side="left", padx=(2,10))

        tk.Label(af_row, text="Qty:", **lbl_cfg).pack(side="left")
        v_qty = tk.StringVar()
        ttk.Entry(af_row, textvariable=v_qty, width=7).pack(side="left", padx=(2,10))

        tk.Label(af_row, text="Rate(₹):", **lbl_cfg).pack(side="left")
        v_rate = tk.StringVar()
        ttk.Entry(af_row, textvariable=v_rate, width=9).pack(side="left", padx=(2,10))

        tk.Label(af_row, text="GST%:", **lbl_cfg).pack(side="left")
        v_gst = tk.StringVar(value="0")
        ttk.Combobox(af_row, textvariable=v_gst, values=["0","5","12","18","28"],
                     width=5, state="readonly").pack(side="left", padx=(2,10))

        def add_item():
            prod = v_prod.get().strip()
            if not prod:
                messagebox.showerror("Error","Product select karo!"); return
            if not v_bill.get().strip():
                messagebox.showerror("Error","Pehle Sale Bill select karo!"); return
            try:
                qty  = float(v_qty.get()); rate = float(v_rate.get()); gst_p = float(v_gst.get())
                assert qty > 0
            except:
                messagebox.showerror("Error","Qty aur Rate sahi bharo!"); return
            taxable = round(qty * rate, 2)
            gst_amt = round(taxable * gst_p / 100, 2)
            total   = round(taxable + gst_amt, 2)
            _return_items.append({
                "product":prod,"qty":qty,"rate":rate,
                "gst_percent":gst_p,"gst_amt":gst_amt,"total_amt":total
            })
            render_items()
            v_prod.set(""); v_qty.set(""); v_rate.set(""); v_gst.set("0")

        make_btn(af_row, "+ Add Item", add_item, bg=C_RED, pady=4).pack(side="left", padx=6)

        # ── Items list table ──────────────────────────────────────────────
        item_tbl = make_table(p,
            ["#","Product","Qty","Rate","GST%","GST Amt","Total","✕"],
            [3, 24, 6, 10, 6, 10, 10, 4])

        # ── Grand Total bar ──────────────────────────────────────────────
        tot_f = tk.Frame(p, bg=C_WHITE, highlightthickness=1, highlightbackground=C_BORDER)
        tot_f.pack(fill="x", pady=4)
        v_grand_lbl = tk.StringVar(value="Return Total: ₹0")
        tk.Label(tot_f, textvariable=v_grand_lbl, font=("Segoe UI",12,"bold"),
                 bg=C_WHITE, fg=C_RED).pack(side="left", padx=16, pady=8)

        def render_items():
            clear_table_rows(item_tbl)
            grand = 0
            for i, it in enumerate(_return_items):
                grand += it["total_amt"]
                bg = C_WHITE if i%2==0 else "#FFF5F5"
                vals = [i+1, it["product"][:22], it["qty"],
                        f"₹{it['rate']:.2f}", f"{it['gst_percent']}%",
                        f"₹{it['gst_amt']:.2f}", f"₹{it['total_amt']:.2f}", ""]
                for j, val in enumerate(vals):
                    if j == 7:
                        tk.Button(item_tbl, text="✕", font=("Segoe UI",9),
                                  bg=bg, fg=C_RED, relief="flat", cursor="hand2", bd=0,
                                  command=lambda idx=i: (_return_items.pop(idx), render_items())
                                  ).grid(row=i+1, column=j, sticky="nsew", padx=1)
                    else:
                        tk.Label(item_tbl, text=str(val), font=("Segoe UI",9),
                                 bg=bg, fg=C_GRAY, anchor="w", padx=6, pady=4
                                 ).grid(row=i+1, column=j, sticky="nsew", padx=1)
            v_grand_lbl.set(f"Return Total: ₹{round(grand):,}  |  Items: {len(_return_items)}")

        def on_bill(ev=None):
            bn = v_bill.get().strip()
            if not bn: return
            d = get_db()
            row = d.execute("SELECT party FROM sales WHERE bill_no=?", (bn,)).fetchone()
            prods = [x[0] for x in d.execute(
                "SELECT DISTINCT si.product FROM sale_items si "
                "JOIN sales s ON si.sale_id=s.id WHERE s.bill_no=?", (bn,)).fetchall()]
            d.close()
            if row:
                e_party.config(state="normal"); v_party.set(row["party"]); e_party.config(state="readonly")
            cb_prod["values"] = prods
            _return_items.clear(); render_items()

        def on_prod(ev=None):
            bn = v_bill.get().strip(); pr = v_prod.get().strip()
            if not bn or not pr: return
            d = get_db()
            row = d.execute(
                "SELECT si.rate,si.gst_percent FROM sale_items si "
                "JOIN sales s ON si.sale_id=s.id WHERE s.bill_no=? AND si.product=? LIMIT 1",
                (bn, pr)).fetchone()
            d.close()
            if row:
                v_rate.set(str(round(row["rate"],2)))
                v_gst.set(str(round(row["gst_percent"],1)))

        cb_bill.bind("<<ComboboxSelected>>", on_bill)
        cb_prod.bind("<<ComboboxSelected>>", on_prod)

        def do_save_and_bill():
            if not _return_items:
                messagebox.showerror("Error","Koi item add nahi kiya!"); return
            bill = v_bill.get().strip(); party = v_party.get().strip()
            if not bill or not party:
                messagebox.showerror("Error","Sale Bill aur Customer zaroori hai!"); return
            d = get_db()
            n = d.execute("SELECT COUNT(*) FROM returns").fetchone()[0]
            rno = "SR-{:03d}".format(n+1)
            grand = sum(it["total_amt"] for it in _return_items)
            # Save each item as separate return row
            for it in _return_items:
                d.execute(
                    "INSERT INTO returns(return_no,return_type,return_date,orig_bill,party,"
                    "product,qty,rate,gst_percent,gst_amt,total_amt,reason) VALUES(?,?,?,?,?,?,?,?,?,?,?,?)",
                    (rno,"sale_return",v_date.get(),bill,party,
                     it["product"],it["qty"],it["rate"],it["gst_percent"],it["gst_amt"],it["total_amt"],
                     v_reason.get().strip()))
                # Stock wapas add karo
                d.execute("UPDATE products SET opening_stock=opening_stock+? WHERE name=?",
                          (it["qty"], it["product"]))
            d.commit(); d.close()
            _show_return_bill(rno, bill, party, _return_items[:], v_date.get(), grand, v_reason.get(), "Sale Return")
            _return_items.clear(); render_items()
            v_bill.set(""); e_party.config(state="normal"); v_party.set(""); e_party.config(state="readonly")
            v_reason.set("")
            load_hist()

        def _show_return_bill(rno, orig_bill, party, items, ret_date, grand, reason, rtype):
            """Return ka popup bill print window."""
            win = tk.Toplevel(p.winfo_toplevel())
            win.title(f"Return Bill — {rno}")
            win.geometry("600x640"); win.configure(bg=C_WHITE)

            _sp = get_shop()
            # Toolbar
            tb = tk.Frame(win, bg="#9B2C2C", pady=6); tb.pack(fill="x")
            make_btn(tb, "🖨️ Print / Save PDF", lambda: _print_return_pdf(rno,orig_bill,party,items,ret_date,grand,reason,rtype),
                     bg="#742A2A", pady=5).pack(side="left", padx=10)
            make_btn(tb, "✕ Close", win.destroy, bg="#5C3D2E", pady=5).pack(side="left", padx=4)
            tk.Label(tb, text=f"Return No: {rno}", font=("Segoe UI",10,"bold"),
                     bg="#9B2C2C", fg="white").pack(side="left", padx=16)

            # Paper
            paper = tk.Frame(win, bg=C_WHITE, padx=24, pady=16); paper.pack(fill="both", expand=True)

            # Header
            tk.Label(paper, text=rtype.upper(), font=("Arial",13,"bold"), bg=C_WHITE, fg="#9B2C2C").pack()
            tk.Label(paper, text=_sp['name'], font=("Arial",11,"bold"), bg=C_WHITE, fg="#5C1A1A").pack()
            if _sp['address']:
                tk.Label(paper, text=f"{_sp['address']}, {_sp['city']}", font=("Arial",9), bg=C_WHITE, fg=C_GRAY).pack()
            if _sp['mobile']:
                tk.Label(paper, text=f"Mob: {_sp['mobile']}", font=("Arial",9), bg=C_WHITE, fg=C_GRAY).pack()
            if _sp['gstin']:
                tk.Label(paper, text=f"GSTIN: {_sp['gstin']}", font=("Arial",9), bg=C_WHITE, fg=C_GRAY).pack()
            tk.Frame(paper, bg="#9B2C2C", height=2).pack(fill="x", pady=8)

            # Bill info
            info_f = tk.Frame(paper, bg=C_WHITE); info_f.pack(fill="x")
            info_f.columnconfigure(0, weight=1); info_f.columnconfigure(1, weight=1)
            tk.Label(info_f, text=f"Return No: {rno}", font=("Arial",9,"bold"), bg=C_WHITE, anchor="w").grid(row=0,column=0,sticky="w")
            tk.Label(info_f, text=f"Date: {fmt_date(ret_date)}", font=("Arial",9), bg=C_WHITE, anchor="e").grid(row=0,column=1,sticky="e")
            tk.Label(info_f, text=f"Against Bill: {orig_bill}", font=("Arial",9), bg=C_WHITE, anchor="w").grid(row=1,column=0,sticky="w")
            tk.Label(info_f, text=f"Customer: {party}", font=("Arial",9), bg=C_WHITE, anchor="w").grid(row=2,column=0,columnspan=2,sticky="w")
            if reason:
                tk.Label(info_f, text=f"Reason: {reason}", font=("Arial",9,"italic"), bg=C_WHITE, fg=C_AMBER, anchor="w").grid(row=3,column=0,columnspan=2,sticky="w")
            tk.Frame(paper, bg=C_BORDER, height=1).pack(fill="x", pady=6)

            # Items
            hdr_f = tk.Frame(paper, bg="#FDEBD0"); hdr_f.pack(fill="x")
            hdr_f.columnconfigure(1, weight=1)
            for j,(h,w) in enumerate([("#",3),("Product",20),("Qty",5),("Rate",8),("GST%",5),("GST Amt",8),("Total",9)]):
                tk.Label(hdr_f, text=h, font=("Arial",8,"bold"), bg="#FDEBD0", fg="#5C1A1A",
                         anchor="w" if j==1 else "center", padx=5, pady=4, width=w).grid(row=0,column=j,sticky="nsew")

            total_taxable = 0; total_gst_sum = 0
            for i, it in enumerate(items):
                bg = C_WHITE if i%2==0 else "#FFF5F5"
                row_f = tk.Frame(paper, bg=bg); row_f.pack(fill="x")
                row_f.columnconfigure(1, weight=1)
                taxbl = round(it["qty"]*it["rate"],2)
                total_taxable += taxbl; total_gst_sum += it["gst_amt"]
                for j,(val,w) in enumerate([(i+1,3),(it["product"][:22],20),(it["qty"],5),
                    (f"₹{it['rate']:.2f}",8),(f"{it['gst_percent']}%",5),
                    (f"₹{it['gst_amt']:.2f}",8),(f"₹{it['total_amt']:.2f}",9)]):
                    tk.Label(row_f, text=str(val), font=("Arial",9), bg=bg, fg=C_GRAY,
                             anchor="w" if j==1 else "center", padx=5, pady=3, width=w).grid(row=0,column=j,sticky="nsew")

            tk.Frame(paper, bg=C_BORDER, height=1).pack(fill="x", pady=4)
            # Totals
            tot_frame = tk.Frame(paper, bg=C_WHITE); tot_frame.pack(anchor="e")
            for lbl, val in [("Taxable Amount:", f"₹{total_taxable:.2f}"),
                              ("GST Amount:", f"₹{total_gst_sum:.2f}"),
                              ("Grand Total:", f"₹{grand:.2f}")]:
                rf = tk.Frame(tot_frame, bg=C_WHITE); rf.pack(fill="x")
                bold = lbl.startswith("Grand")
                tk.Label(rf, text=lbl, font=("Arial",9,"bold" if bold else "normal"),
                         bg=C_WHITE, fg="#5C1A1A" if bold else C_GRAY, anchor="e", width=18).pack(side="left")
                tk.Label(rf, text=val, font=("Arial",9,"bold" if bold else "normal"),
                         bg=C_WHITE, fg=C_RED if bold else C_GRAY, anchor="e", width=12).pack(side="left")
            tk.Label(paper, text=num_to_words(grand), font=("Arial",8,"italic"),
                     bg=C_WHITE, fg=C_LGRAY, wraplength=500, justify="left").pack(anchor="w", pady=4)
            tk.Frame(paper, bg="#9B2C2C", height=2).pack(fill="x", pady=4)
            tk.Label(paper, text="Authorized Signatory", font=("Arial",9), bg=C_WHITE, fg=C_LGRAY).pack(anchor="e", padx=20)

        def _print_return_pdf(rno, orig_bill, party, items, ret_date, grand, reason, rtype):
            """Return Bill PDF banao aur open karo."""
            try:
                from reportlab.lib.pagesizes import A4
                from reportlab.lib import colors
                from reportlab.lib.units import mm
                from reportlab.platypus import SimpleDocTemplate, Table, TableStyle, Paragraph, Spacer
                from reportlab.lib.styles import ParagraphStyle
                from reportlab.lib.enums import TA_CENTER, TA_RIGHT, TA_LEFT
                from tkinter import filedialog
                import os, sys

                save_path = filedialog.asksaveasfilename(
                    defaultextension=".pdf",
                    filetypes=[("PDF","*.pdf")],
                    initialfile=f"{rno}.pdf",
                    title="Return Bill PDF save karo")
                if not save_path: return

                _sp = get_shop()
                PAGE_W = 190*mm
                BDR = colors.black

                def ps(nm, sz=9, bold=False, align=TA_LEFT):
                    return ParagraphStyle(nm, fontSize=sz,
                        fontName="Helvetica-Bold" if bold else "Helvetica",
                        alignment=align, leading=sz+3)

                BASE = [("BOX",(0,0),(-1,-1),0.5,BDR),
                        ("INNERGRID",(0,0),(-1,-1),0.3,BDR),
                        ("TOPPADDING",(0,0),(-1,-1),3),
                        ("BOTTOMPADDING",(0,0),(-1,-1),3),
                        ("LEFTPADDING",(0,0),(-1,-1),3),
                        ("RIGHTPADDING",(0,0),(-1,-1),3)]

                doc = SimpleDocTemplate(save_path, pagesize=A4,
                    leftMargin=12*mm, rightMargin=12*mm,
                    topMargin=10*mm, bottomMargin=10*mm)
                story = []

                RED = colors.HexColor("#9B2C2C")

                # Title
                story.append(Table([[Paragraph(rtype.upper(), ps("t",13,True,TA_CENTER))]],
                    [PAGE_W], [("BOX",(0,0),(-1,-1),1,RED),
                               ("BACKGROUND",(0,0),(-1,-1),RED),
                               ("TEXTCOLOR",(0,0),(-1,-1),colors.white),
                               ("TOPPADDING",(0,0),(-1,-1),6),
                               ("BOTTOMPADDING",(0,0),(-1,-1),6)]))
                story.append(Spacer(1, 2*mm))

                # Shop info
                shop_txt = (f"<b>{_sp['name']}</b><br/>"
                    + (f"{_sp['address']}, {_sp['city']}<br/>" if _sp['address'] else "")
                    + (f"Mob: {_sp['mobile']}<br/>" if _sp['mobile'] else "")
                    + (f"GSTIN: {_sp['gstin']}" if _sp['gstin'] else ""))
                bill_info = (f"<b>Return No:</b> {rno}<br/>"
                    f"<b>Date:</b> {fmt_date(ret_date)}<br/>"
                    f"<b>Against Bill:</b> {orig_bill}<br/>"
                    f"<b>Customer:</b> {party}"
                    + (f"<br/><b>Reason:</b> {reason}" if reason else ""))

                story.append(Table([[Paragraph(shop_txt,ps("sh",9)),
                                     Paragraph(bill_info,ps("bi",9))]],
                    [110*mm, 80*mm], BASE))

                # Items
                hdr = [Paragraph(x, ps("h",8,True,TA_CENTER)) for x in
                       ["Sl","Product","Qty","Rate(₹)","GST%","GST Amt","Total(₹)"]]
                rows = [hdr]
                total_taxable = 0; total_gst_sum = 0
                for i,it in enumerate(items,1):
                    taxbl = round(it["qty"]*it["rate"],2)
                    total_taxable += taxbl; total_gst_sum += it["gst_amt"]
                    rows.append([
                        Paragraph(str(i),ps("r",8,align=TA_CENTER)),
                        Paragraph(it["product"],ps("r",8)),
                        Paragraph(str(it["qty"]),ps("r",8,align=TA_CENTER)),
                        Paragraph(f"{it['rate']:.2f}",ps("r",8,align=TA_RIGHT)),
                        Paragraph(f"{it['gst_percent']}%",ps("r",8,align=TA_CENTER)),
                        Paragraph(f"{it['gst_amt']:.2f}",ps("r",8,align=TA_RIGHT)),
                        Paragraph(f"{it['total_amt']:.2f}",ps("r",8,align=TA_RIGHT)),
                    ])
                # Total row
                rows.append([Paragraph(""),Paragraph("<b>Total</b>",ps("r",9,True)),
                    Paragraph(""),Paragraph(""),Paragraph(""),
                    Paragraph(f"<b>{total_gst_sum:.2f}</b>",ps("r",9,True,TA_RIGHT)),
                    Paragraph(f"<b>{grand:.2f}</b>",ps("r",9,True,TA_RIGHT))])

                story.append(Spacer(1,3*mm))
                story.append(Table(rows,[10*mm,70*mm,18*mm,22*mm,14*mm,22*mm,24*mm],
                    BASE+[("BACKGROUND",(0,0),(-1,0),colors.HexColor("#FDEBD0")),
                          ("BACKGROUND",(0,-1),(-1,-1),colors.HexColor("#FFF5F5"))]))

                # Amount in words
                story.append(Spacer(1,2*mm))
                story.append(Table([
                    [Paragraph(f"Amount: <b>{num_to_words(grand)}</b>",ps("aw",8))],
                    [Paragraph(f"Reason: {reason}" if reason else "",ps("aw",8,"italic"))]],
                    [PAGE_W], BASE))

                # Signature
                story.append(Spacer(1,4*mm))
                story.append(Table([[Paragraph(""),
                    Paragraph(f"For {_sp['name']}<br/><br/><br/>Authorized Signatory",
                               ps("sg",9,align=TA_RIGHT))]],
                    [110*mm,80*mm], BASE+[("BOTTOMPADDING",(0,0),(-1,-1),18)]))

                doc.build(story)
                import subprocess
                if sys.platform=="win32": os.startfile(save_path)
                elif sys.platform=="darwin": subprocess.Popen(["open",save_path])
                else: subprocess.Popen(["xdg-open",save_path])
                messagebox.showinfo("PDF Ready!", f"Return Bill PDF save ho gayi:\n{save_path}")
            except ImportError:
                messagebox.showerror("Library Missing",
                    "reportlab install nahi hai.\n\nCMD mein chalao:\npip install reportlab")
            except Exception as e:
                messagebox.showerror("Error", f"PDF nahi ban saki:\n{str(e)}")

        # ── Buttons ──────────────────────────────────────────────────────
        bf = tk.Frame(p, bg=C_BG); bf.pack(fill="x", pady=6)
        make_btn(bf,"💾 Save & Print Return Bill", do_save_and_bill, bg=C_RED).pack(side="left", padx=(0,8))
        make_btn(bf,"🗑️ Clear Items",
                 lambda: [_return_items.clear(), render_items()], bg=C_GRAY).pack(side="left")

        # ── Return History ────────────────────────────────────────────────
        divider(p)
        make_label(p, "📋  Sale Return History", 11, True, color="#5C1A1A").pack(anchor="w", pady=(4,6))

        # Filter
        hf = tk.Frame(p, bg=C_BG); hf.pack(fill="x", pady=(0,4))
        tk.Label(hf,text="Search:",font=("Segoe UI",9),bg=C_BG,fg=C_GRAY).pack(side="left")
        v_search = tk.StringVar()
        ttk.Entry(hf,textvariable=v_search,width=22).pack(side="left",padx=6)
        make_btn(hf,"🔍 Filter",lambda:load_hist(),bg="#2B6CB0").pack(side="left",padx=4)

        tbl = make_table(p,
            ["Return No","Date","Orig Bill","Customer","Product","Qty","Total","Reason","Bill"],
            [11,11,12,16,18,6,10,14,6])

        def load_hist():
            clear_table_rows(tbl)
            q_txt = v_search.get().lower()
            d = get_db()
            rows = d.execute(
                "SELECT * FROM returns WHERE return_type='sale_return' ORDER BY return_date DESC"
            ).fetchall()
            d.close()
            # Group by return_no for bill button
            seen = {}
            ri = 0
            for r in rows:
                if q_txt and q_txt not in r["return_no"].lower() and \
                   q_txt not in r["party"].lower() and q_txt not in r["product"].lower():
                    continue
                rno = r["return_no"]
                bg = C_WHITE if ri%2==0 else "#FFF5F5"
                for j, val in enumerate([r["return_no"], fmt_date(r["return_date"]),
                    r["orig_bill"], r["party"][:14], r["product"][:16],
                    str(r["qty"]), f"₹{int(r['total_amt'])}", (r["reason"] or "")[:12], ""]):
                    if j == 8:
                        tk.Button(tbl, text="📄", font=("Segoe UI",9),
                                  bg=C_RED, fg="white", relief="flat", cursor="hand2",
                                  command=lambda rn=rno: _view_return_bill(rn)
                                  ).grid(row=ri+1, column=j, sticky="nsew", padx=2, pady=2)
                    else:
                        tk.Label(tbl, text=str(val), font=("Segoe UI",9),
                                 bg=bg, fg=C_GRAY, anchor="w", padx=5, pady=4
                                 ).grid(row=ri+1, column=j, sticky="nsew", padx=1)
                ri += 1

        def _view_return_bill(rno):
            d = get_db()
            rows = d.execute("SELECT * FROM returns WHERE return_no=?", (rno,)).fetchall()
            d.close()
            if not rows: return
            items = [{"product":r["product"],"qty":r["qty"],"rate":r["rate"],
                      "gst_percent":r["gst_percent"],"gst_amt":r["gst_amt"],"total_amt":r["total_amt"]}
                     for r in rows]
            grand = sum(r["total_amt"] for r in rows)
            _show_return_bill(rows[0]["return_no"], rows[0]["orig_bill"],
                              rows[0]["party"], items,
                              rows[0]["return_date"], grand,
                              rows[0]["reason"] or "", "Sale Return")

        load_hist()

    # ══════════════════════════════════════════════════════════════════════════
    #  PURCHASE RETURN
    # ══════════════════════════════════════════════════════════════════════════
    def _pg_purreturn(self):
        """Purchase Return — Ek se zyada products, Return Bill generate."""
        import datetime as _dt
        db = get_db()
        db.execute("""CREATE TABLE IF NOT EXISTS returns (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            return_no TEXT UNIQUE NOT NULL,
            return_type TEXT NOT NULL,
            return_date TEXT NOT NULL,
            orig_bill TEXT NOT NULL,
            party TEXT NOT NULL,
            product TEXT NOT NULL,
            qty REAL DEFAULT 0,
            rate REAL DEFAULT 0,
            gst_percent REAL DEFAULT 0,
            gst_amt REAL DEFAULT 0,
            total_amt REAL DEFAULT 0,
            reason TEXT DEFAULT '',
            created_at TEXT DEFAULT CURRENT_TIMESTAMP)""")
        db.commit(); db.close()

        _return_items = []

        p = tk.Frame(self.content, bg=C_BG, padx=14, pady=6)
        p.pack(fill="x")
        section_title(p, "↩️ Purchase Return — Supplier ko Maal Wapas")

        form = tk.Frame(p, bg=C_WHITE, highlightthickness=1, highlightbackground=C_BORDER)
        form.pack(fill="x", pady=(0,8))
        tk.Label(form, text="Supplier Return Entry  (Ek bill ke multiple products return kar sakte ho)",
                 font=("Segoe UI",10,"bold"), bg=C_WHITE, fg="#5C1A1A").pack(anchor="w", padx=16, pady=(10,6))

        row1 = tk.Frame(form, bg=C_WHITE); row1.pack(fill="x", padx=16, pady=4)

        tk.Label(row1, text="Return Date:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_date = tk.StringVar(value=str(_dt.date.today()))
        make_date_entry(row1, v_date, width=13).pack(side="left", padx=(2,14))

        tk.Label(row1, text="Purchase Bill No:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_bill = tk.StringVar()
        db2 = get_db()
        bills = [r[0] for r in db2.execute("SELECT bill_no FROM purchases ORDER BY bill_date DESC").fetchall()]
        db2.close()
        cb_bill = ttk.Combobox(row1, textvariable=v_bill, values=bills, width=16)
        cb_bill.pack(side="left", padx=(2,14))

        tk.Label(row1, text="Supplier:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_party = tk.StringVar()
        e_party = ttk.Entry(row1, textvariable=v_party, width=20, state="readonly")
        e_party.pack(side="left", padx=(2,0))

        row_r = tk.Frame(form, bg=C_WHITE); row_r.pack(fill="x", padx=16, pady=4)
        tk.Label(row_r, text="Return Reason:", font=("Segoe UI",9), bg=C_WHITE, fg=C_GRAY).pack(side="left")
        v_reason = tk.StringVar()
        ttk.Combobox(row_r, textvariable=v_reason, width=38,
                     values=["Defective / Kharab Maal","Wrong Item Supplied","Excess Quantity",
                             "Quality Issue","Damage in Transit","Not as per Order","Other"]).pack(side="left", padx=(4,0))

        # ── Add Item Area ──────────────────────────────────────────────────
        af = tk.Frame(p, bg="#F0FFF4", highlightthickness=1, highlightbackground="#9AE6B4")
        af.pack(fill="x", pady=(0,6))
        tk.Label(af, text="➕  Item Add Karo  (Bill select karne ke baad products auto-fill honge)",
                 font=("Segoe UI",9,"bold"), bg="#F0FFF4", fg="#276749").pack(anchor="w", padx=12, pady=(8,4))

        af_row = tk.Frame(af, bg="#F0FFF4"); af_row.pack(fill="x", padx=12, pady=(0,8))
        lbl_cfg = dict(font=("Segoe UI",8,"bold"), bg="#F0FFF4", fg="#276749")

        tk.Label(af_row, text="Product:", **lbl_cfg).pack(side="left")
        v_prod = tk.StringVar()
        cb_prod = ttk.Combobox(af_row, textvariable=v_prod, width=22)
        cb_prod.pack(side="left", padx=(2,10))

        tk.Label(af_row, text="Qty:", **lbl_cfg).pack(side="left")
        v_qty = tk.StringVar()
        ttk.Entry(af_row, textvariable=v_qty, width=7).pack(side="left", padx=(2,10))

        tk.Label(af_row, text="Rate(₹):", **lbl_cfg).pack(side="left")
        v_rate = tk.StringVar()
        ttk.Entry(af_row, textvariable=v_rate, width=9).pack(side="left", padx=(2,10))

        tk.Label(af_row, text="GST%:", **lbl_cfg).pack(side="left")
        v_gst = tk.StringVar(value="0")
        ttk.Combobox(af_row, textvariable=v_gst, values=["0","5","12","18","28"],
                     width=5, state="readonly").pack(side="left", padx=(2,10))

        def add_item():
            prod = v_prod.get().strip()
            if not prod:
                messagebox.showerror("Error","Product select karo!"); return
            if not v_bill.get().strip():
                messagebox.showerror("Error","Pehle Purchase Bill select karo!"); return
            try:
                qty  = float(v_qty.get()); rate = float(v_rate.get()); gst_p = float(v_gst.get())
                assert qty > 0
            except:
                messagebox.showerror("Error","Qty aur Rate sahi bharo!"); return
            taxable = round(qty * rate, 2)
            gst_amt = round(taxable * gst_p / 100, 2)
            total   = round(taxable + gst_amt, 2)
            _return_items.append({
                "product":prod,"qty":qty,"rate":rate,
                "gst_percent":gst_p,"gst_amt":gst_amt,"total_amt":total
            })
            render_items()
            v_prod.set(""); v_qty.set(""); v_rate.set(""); v_gst.set("0")

        make_btn(af_row, "+ Add Item", add_item, bg=C_GREEN, pady=4).pack(side="left", padx=6)

        item_tbl = make_table(p,
            ["#","Product","Qty","Rate","GST%","GST Amt","Total","✕"],
            [3, 24, 6, 10, 6, 10, 10, 4])

        tot_f = tk.Frame(p, bg=C_WHITE, highlightthickness=1, highlightbackground=C_BORDER)
        tot_f.pack(fill="x", pady=4)
        v_grand_lbl = tk.StringVar(value="Return Total: ₹0")
        tk.Label(tot_f, textvariable=v_grand_lbl, font=("Segoe UI",12,"bold"),
                 bg=C_WHITE, fg=C_GREEN).pack(side="left", padx=16, pady=8)

        def render_items():
            clear_table_rows(item_tbl)
            grand = 0
            for i, it in enumerate(_return_items):
                grand += it["total_amt"]
                bg = C_WHITE if i%2==0 else "#F0FFF4"
                vals = [i+1, it["product"][:22], it["qty"],
                        f"₹{it['rate']:.2f}", f"{it['gst_percent']}%",
                        f"₹{it['gst_amt']:.2f}", f"₹{it['total_amt']:.2f}", ""]
                for j, val in enumerate(vals):
                    if j == 7:
                        tk.Button(item_tbl, text="✕", font=("Segoe UI",9),
                                  bg=bg, fg=C_RED, relief="flat", cursor="hand2", bd=0,
                                  command=lambda idx=i: (_return_items.pop(idx), render_items())
                                  ).grid(row=i+1, column=j, sticky="nsew", padx=1)
                    else:
                        tk.Label(item_tbl, text=str(val), font=("Segoe UI",9),
                                 bg=bg, fg=C_GRAY, anchor="w", padx=6, pady=4
                                 ).grid(row=i+1, column=j, sticky="nsew", padx=1)
            v_grand_lbl.set(f"Return Total: ₹{round(grand):,}  |  Items: {len(_return_items)}")

        def on_bill(ev=None):
            bn = v_bill.get().strip()
            if not bn: return
            d = get_db()
            row = d.execute("SELECT party FROM purchases WHERE bill_no=?", (bn,)).fetchone()
            prods = [x[0] for x in d.execute(
                "SELECT DISTINCT pi.product FROM purchase_items pi "
                "JOIN purchases pu ON pi.purchase_id=pu.id WHERE pu.bill_no=?", (bn,)).fetchall()]
            d.close()
            if row:
                e_party.config(state="normal"); v_party.set(row["party"]); e_party.config(state="readonly")
            cb_prod["values"] = prods
            _return_items.clear(); render_items()

        def on_prod(ev=None):
            bn = v_bill.get().strip(); pr = v_prod.get().strip()
            if not bn or not pr: return
            d = get_db()
            row = d.execute(
                "SELECT pi.rate,pi.gst_percent FROM purchase_items pi "
                "JOIN purchases pu ON pi.purchase_id=pu.id WHERE pu.bill_no=? AND pi.product=? LIMIT 1",
                (bn, pr)).fetchone()
            d.close()
            if row:
                v_rate.set(str(round(row["rate"],2)))
                v_gst.set(str(round(row["gst_percent"],1)))

        cb_bill.bind("<<ComboboxSelected>>", on_bill)
        cb_prod.bind("<<ComboboxSelected>>", on_prod)

        def do_save_and_bill():
            if not _return_items:
                messagebox.showerror("Error","Koi item add nahi kiya!"); return
            bill = v_bill.get().strip(); party = v_party.get().strip()
            if not bill or not party:
                messagebox.showerror("Error","Purchase Bill aur Supplier zaroori hai!"); return
            d = get_db()
            n = d.execute("SELECT COUNT(*) FROM returns").fetchone()[0]
            rno = "PR-{:03d}".format(n+1)
            grand = sum(it["total_amt"] for it in _return_items)
            for it in _return_items:
                d.execute(
                    "INSERT INTO returns(return_no,return_type,return_date,orig_bill,party,"
                    "product,qty,rate,gst_percent,gst_amt,total_amt,reason) VALUES(?,?,?,?,?,?,?,?,?,?,?,?)",
                    (rno,"pur_return",v_date.get(),bill,party,
                     it["product"],it["qty"],it["rate"],it["gst_percent"],it["gst_amt"],it["total_amt"],
                     v_reason.get().strip()))
                # Stock kam karo (wapas supplier ko gaya)
                d.execute("UPDATE products SET opening_stock=opening_stock-? WHERE name=?",
                          (it["qty"], it["product"]))
            d.commit(); d.close()
            _show_return_bill(rno, bill, party, _return_items[:], v_date.get(), grand, v_reason.get(), "Purchase Return")
            _return_items.clear(); render_items()
            v_bill.set(""); e_party.config(state="normal"); v_party.set(""); e_party.config(state="readonly")
            v_reason.set("")
            load_hist()

        def _show_return_bill(rno, orig_bill, party, items, ret_date, grand, reason, rtype):
            win = tk.Toplevel(p.winfo_toplevel())
            win.title(f"Return Bill — {rno}")
            win.geometry("600x640"); win.configure(bg=C_WHITE)
            _sp = get_shop()
            tb = tk.Frame(win, bg="#276749", pady=6); tb.pack(fill="x")
            make_btn(tb, "🖨️ Print / Save PDF",
                     lambda: _print_return_pdf(rno,orig_bill,party,items,ret_date,grand,reason,rtype),
                     bg="#1C4532", pady=5).pack(side="left", padx=10)
            make_btn(tb, "✕ Close", win.destroy, bg="#5C3D2E", pady=5).pack(side="left", padx=4)
            tk.Label(tb, text=f"Return No: {rno}", font=("Segoe UI",10,"bold"),
                     bg="#276749", fg="white").pack(side="left", padx=16)

            paper = tk.Frame(win, bg=C_WHITE, padx=24, pady=16); paper.pack(fill="both", expand=True)
            tk.Label(paper, text=rtype.upper(), font=("Arial",13,"bold"), bg=C_WHITE, fg="#276749").pack()
            tk.Label(paper, text=_sp['name'], font=("Arial",11,"bold"), bg=C_WHITE, fg="#5C1A1A").pack()
            if _sp['address']:
                tk.Label(paper, text=f"{_sp['address']}, {_sp['city']}", font=("Arial",9), bg=C_WHITE, fg=C_GRAY).pack()
            if _sp['mobile']:
                tk.Label(paper, text=f"Mob: {_sp['mobile']}", font=("Arial",9), bg=C_WHITE, fg=C_GRAY).pack()
            tk.Frame(paper, bg="#276749", height=2).pack(fill="x", pady=8)
            info_f = tk.Frame(paper, bg=C_WHITE); info_f.pack(fill="x")
            info_f.columnconfigure(0, weight=1); info_f.columnconfigure(1, weight=1)
            tk.Label(info_f, text=f"Return No: {rno}", font=("Arial",9,"bold"), bg=C_WHITE, anchor="w").grid(row=0,column=0,sticky="w")
            tk.Label(info_f, text=f"Date: {fmt_date(ret_date)}", font=("Arial",9), bg=C_WHITE, anchor="e").grid(row=0,column=1,sticky="e")
            tk.Label(info_f, text=f"Against Bill: {orig_bill}", font=("Arial",9), bg=C_WHITE, anchor="w").grid(row=1,column=0,sticky="w")
            tk.Label(info_f, text=f"Supplier: {party}", font=("Arial",9), bg=C_WHITE, anchor="w").grid(row=2,column=0,columnspan=2,sticky="w")
            if reason:
                tk.Label(info_f, text=f"Reason: {reason}", font=("Arial",9,"italic"), bg=C_WHITE, fg=C_AMBER, anchor="w").grid(row=3,column=0,columnspan=2,sticky="w")
            tk.Frame(paper, bg=C_BORDER, height=1).pack(fill="x", pady=6)
            hdr_f = tk.Frame(paper, bg="#FDEBD0"); hdr_f.pack(fill="x")
            for j,(h,w) in enumerate([("#",3),("Product",20),("Qty",5),("Rate",8),("GST%",5),("GST Amt",8),("Total",9)]):
                tk.Label(hdr_f, text=h, font=("Arial",8,"bold"), bg="#FDEBD0", fg="#5C1A1A",
                         anchor="w" if j==1 else "center", padx=5, pady=4, width=w).grid(row=0,column=j,sticky="nsew")
            total_taxable = 0; total_gst_sum = 0
            for i, it in enumerate(items):
                bg = C_WHITE if i%2==0 else "#F0FFF4"
                row_f = tk.Frame(paper, bg=bg); row_f.pack(fill="x")
                taxbl = round(it["qty"]*it["rate"],2)
                total_taxable += taxbl; total_gst_sum += it["gst_amt"]
                for j,(val,w) in enumerate([(i+1,3),(it["product"][:22],20),(it["qty"],5),
                    (f"₹{it['rate']:.2f}",8),(f"{it['gst_percent']}%",5),
                    (f"₹{it['gst_amt']:.2f}",8),(f"₹{it['total_amt']:.2f}",9)]):
                    tk.Label(row_f, text=str(val), font=("Arial",9), bg=bg, fg=C_GRAY,
                             anchor="w" if j==1 else "center", padx=5, pady=3, width=w).grid(row=0,column=j,sticky="nsew")
            tk.Frame(paper, bg=C_BORDER, height=1).pack(fill="x", pady=4)
            tot_frame = tk.Frame(paper, bg=C_WHITE); tot_frame.pack(anchor="e")
            for lbl, val in [("Taxable Amount:", f"₹{total_taxable:.2f}"),
                              ("GST Amount:", f"₹{total_gst_sum:.2f}"),
                              ("Grand Total:", f"₹{grand:.2f}")]:
                rf = tk.Frame(tot_frame, bg=C_WHITE); rf.pack(fill="x")
                bold = lbl.startswith("Grand")
