        def import_from_excel():
            """
            Excel se Products bulk import karo.
            Expected columns (header se auto-detect):
            Type | Product Name | Brand | Category | HSN Code | Purchase Rate | Sale Rate | GST% | Opening Stock | Sizes | Colors | Barcode | Low Stock Alert
            """
            try:
                import openpyxl
            except ImportError:
                messagebox.showerror("openpyxl Missing",
                    "openpyxl install nahi hai.\n\n"
                    "Command Prompt mein yeh chalao:\n"
                    "pip install openpyxl\n\nPhir dobara try karo.")
                return

            from tkinter import filedialog
            filepath = filedialog.askopenfilename(
                title="Products Excel File Select Karo",
                filetypes=[("Excel Files", "*.xlsx *.xls"), ("All Files", "*.*")]
            )
            if not filepath:
                return

            try:
                wb = openpyxl.load_workbook(filepath, data_only=True)
                ws = wb.active

                headers = []
                for cell in ws[1]:
                    val = str(cell.value or "").strip().lower()
                    headers.append(val)

                col_map = {
                    "type":         next((i for i,h in enumerate(headers) if "type" in h), None),
                    "name":         next((i for i,h in enumerate(headers) if "product" in h or ("name" in h and "brand" not in h)), None),
                    "brand":        next((i for i,h in enumerate(headers) if "brand" in h), None),
                    "category":     next((i for i,h in enumerate(headers) if "categ" in h), None),
                    "hsn":          next((i for i,h in enumerate(headers) if "hsn" in h), None),
                    "purchase_rate":next((i for i,h in enumerate(headers) if "purchase" in h and "rate" in h), None),
                    "sale_rate":    next((i for i,h in enumerate(headers) if "sale" in h and "rate" in h), None),
                    "gst":          next((i for i,h in enumerate(headers) if "gst" in h), None),
                    "stock":        next((i for i,h in enumerate(headers) if "stock" in h and "alert" not in h and "low" not in h), None),
                    "sizes":        next((i for i,h in enumerate(headers) if "size" in h), None),
                    "colors":       next((i for i,h in enumerate(headers) if "color" in h or "colour" in h), None),
                    "barcode":      next((i for i,h in enumerate(headers) if "barcode" in h or "qr" in h), None),
                    "alert":        next((i for i,h in enumerate(headers) if "alert" in h or "low stock" in h), None),
                }

                if col_map["name"] is None:
                    messagebox.showerror("Column Error",
                        "'Product Name' column nahi mila!\n"
                        "Excel mein column header 'Product Name' ya 'Name' hona chahiye.\n\n"
                        "Pehle 'Import Template Download' se template lo.")
                    return

                def get_val(row_vals, key, default=""):
                    idx = col_map.get(key)
                    if idx is None or idx >= len(row_vals):
                        return default
                    v = row_vals[idx]
                    return str(v).strip() if v is not None else default

                conn = get_db()
                added = 0; skipped = 0; errors = []

                for row_num, row in enumerate(ws.iter_rows(min_row=2, values_only=True), start=2):
                    row_vals = list(row)
                    if not any(v for v in row_vals):
                        continue

                    name = get_val(row_vals, "name")
                    if not name or name.lower() == "none":
                        continue

                    existing = conn.execute("SELECT id FROM products WHERE name=?", (name,)).fetchone()
                    if existing:
                        skipped += 1
                        continue

                    try:
                        sale_rate     = float(str(get_val(row_vals, "sale_rate", "0")).replace("₹","").replace(",","") or 0)
                        purchase_rate = float(str(get_val(row_vals, "purchase_rate", "0")).replace("₹","").replace(",","") or 0)
                        opening_stock = float(str(get_val(row_vals, "stock", "0")).replace(",","") or 0)
                        gst_str       = str(get_val(row_vals, "gst", "5")).replace("%","").strip()
                        gst_percent   = float(gst_str or 5)
                        alert         = float(str(get_val(row_vals, "alert", "5")).replace(",","") or 5)
                    except Exception as e:
                        errors.append(f"Row {row_num} ({name}): {e}")
                        continue

                    prod_type = get_val(row_vals, "type", "Clothes")
                    brand     = get_val(row_vals, "brand", "")
                    category  = get_val(row_vals, "category", "Other")
                    hsn       = get_val(row_vals, "hsn", "6203")
                    sizes     = get_val(row_vals, "sizes", "S,M,L,XL,XXL")
                    colors    = get_val(row_vals, "colors", "")
                    barcode   = get_val(row_vals, "barcode", "")

                    try:
                        conn.execute("""INSERT INTO products
                            (name,hsn,sale_rate,purchase_rate,gst_percent,opening_stock,
                             low_stock_alert,category,brand,size_options,color_options,product_type,barcode)
                            VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?)""",
                            (name, hsn, sale_rate, purchase_rate, gst_percent, opening_stock,
                             alert, category, brand, sizes, colors, prod_type, barcode))
                        added += 1
                    except sqlite3.IntegrityError:
                        skipped += 1
                    except Exception as e:
                        errors.append(f"Row {row_num} ({name}): {e}")

                conn.commit()
                conn.close()
                refresh()

                msg = f"✅ Import Complete!\n\n✔ Naye products add hue: {added}\n⏭ Already exist (skip): {skipped}"
                if errors:
                    msg += f"\n\n⚠ Errors ({len(errors)}):\n" + "\n".join(errors[:5])
                    if len(errors) > 5:
                        msg += f"\n...aur {len(errors)-5} aur errors"
                messagebox.showinfo("Excel Import", msg)

            except Exception as e:
                messagebox.showerror("Import Error", f"File padhne mein error:\n{str(e)}")

        def download_import_template():
            """Blank Excel template download karo jisme sahi columns hon."""
            try:
                import openpyxl
                from openpyxl.styles import Font, PatternFill, Alignment
                from tkinter import filedialog

                save_path = filedialog.asksaveasfilename(
                    defaultextension=".xlsx",
                    initialfile="Products_Import_Template.xlsx",
                    filetypes=[("Excel", "*.xlsx")]
                )
                if not save_path:
                    return

                wb = openpyxl.Workbook()
                ws = wb.active
                ws.title = "Products"

                headers = ["Type","Product Name","Brand","Category","HSN Code",
                           "Purchase Rate","Sale Rate","GST%","Opening Stock",
                           "Sizes","Colors","Barcode","Low Stock Alert"]
                sample  = ["Clothes","Gents Shirt Blue XL","Arrow","Gents Shirt","6203",
                           "250","499","5","50","S,M,L,XL,XXL","Blue,White","","5"]

                header_fill = PatternFill("solid", fgColor="1A365D")
                sample_fill = PatternFill("solid", fgColor="EBF8FF")
                bold_white  = Font(bold=True, color="FFFFFF", size=10)

                col_widths = [12,30,16,18,10,14,12,7,14,22,18,16,14]
                for i,(h,s,w) in enumerate(zip(headers,sample,col_widths),1):
                    hc = ws.cell(1, i, h)
                    hc.font = bold_white; hc.fill = header_fill
                    hc.alignment = Alignment(horizontal="center")
                    sc = ws.cell(2, i, s)
                    sc.fill = sample_fill
                    ws.column_dimensions[hc.column_letter].width = w

                wb.save(save_path)
                messagebox.showinfo("Template Ready",
                    f"Template save ho gaya!\n{save_path}\n\n"
                    "📌 Instructions:\n"
                    "• Row 1 = Headers (change mat karo)\n"
                    "• Row 2 = Sample (delete kar sakte ho)\n"
                    "• Apna data Row 3 se bharo\n"
                    "• Save karke 'Excel se Import' karo")
            except Exception as e:
                messagebox.showerror("Error", str(e))

